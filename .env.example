# Copy to .env and fill in. .env is git-ignored; never commit real secrets.

# --- Gateway endpoint (NOT the docs host) -----------------------------------
# Base URL of the SCP Open API gateway your account targets.
SCP_BASE_URL=https://api.samsungsdscloud.com

# --- Credentials ------------------------------------------------------------
SCP_ACCESS_KEY=
SCP_SECRET_KEY=
# Optional project/tenant scope (sent as a header by many services)
SCP_PROJECT_ID=

# --- Auth scheme ------------------------------------------------------------
# hmac (default) | bearer | none. Header names below are configurable so the
# suite can be aligned to the confirmed SCP signing spec without code changes.
SCP_AUTH_SCHEME=hmac
SCP_HMAC_ACCESS_HEADER=x-cmp-accesskey
SCP_HMAC_SIGNATURE_HEADER=x-cmp-signature
SCP_HMAC_TIMESTAMP_HEADER=x-cmp-timestamp
SCP_PROJECT_HEADER=x-cmp-project-id

# --- Run behaviour ----------------------------------------------------------
SCP_TIMEOUT=60
SCP_MAX_RETRIES=4

# --- SAFETY GATES (default off) ---------------------------------------------
# Allow POST/PUT/PATCH (creates/updates real resources).
SCP_ALLOW_MUTATIONS=false
# Additionally allow DELETE (destroys real resources). Keep false unless you
# are sure the lifecycle cleans up only what it created.
SCP_ALLOW_DESTRUCTIVE=false
