# Copy to .env and fill in. .env is git-ignored; never commit real secrets.

# --- Endpoint (per-service hosts) -------------------------------------------
# SCP Open API endpoints are per-service, in two flavours:
#   regional: https://<service>.<region>.<env>.samsungsdscloud.com   (e.g. vpc)
#   global  : https://<service>.<env>.samsungsdscloud.com            (e.g. product)
# Set region (+ env) and the suite builds each service's host automatically;
# the global-service list is built in (product, pricing, iam, billing, ...).
SCP_REGION=kr-west1
SCP_ENV=e
# Override host patterns only if they differ:
# SCP_HOST_TEMPLATE=https://{service}.{region}.{env}.samsungsdscloud.com
# SCP_GLOBAL_HOST_TEMPLATE=https://{service}.{env}.samsungsdscloud.com
# Extend/replace the region-less service set (comma-separated):
# SCP_GLOBAL_SERVICES=product,pricing,iam,organization,quota,...
# Per-service overrides when an API subdomain != catalog service name (JSON):
# SCP_SERVICE_HOSTS={"virtualserver":"vs.kr-west1.e.samsungsdscloud.com"}
# Explicit single-host fallback (only if NOT using region/template):
# SCP_BASE_URL=

# --- Credentials ------------------------------------------------------------
SCP_ACCESS_KEY=
SCP_SECRET_KEY=
# Optional project/tenant scope (sent as a header by many services)
SCP_PROJECT_ID=

# --- Auth scheme ------------------------------------------------------------
# hmac (default) | bearer | none. Header names below are configurable so the
# suite can be aligned to the confirmed SCP signing spec without code changes.
SCP_AUTH_SCHEME=hmac
SCP_HMAC_ACCESS_HEADER=x-cmp-accesskey
SCP_HMAC_SIGNATURE_HEADER=x-cmp-signature
SCP_HMAC_TIMESTAMP_HEADER=x-cmp-timestamp
SCP_PROJECT_HEADER=x-cmp-project-id

# --- Run behaviour ----------------------------------------------------------
SCP_TIMEOUT=60
SCP_MAX_RETRIES=4

# --- SAFETY GATES (default off) ---------------------------------------------
# Allow POST/PUT/PATCH (creates/updates real resources).
SCP_ALLOW_MUTATIONS=false
# Additionally allow DELETE (destroys real resources). Keep false unless you
# are sure the lifecycle cleans up only what it created.
SCP_ALLOW_DESTRUCTIVE=false
