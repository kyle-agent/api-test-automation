    {
      "id": "gen-wave5-swatch-alert",
      "service": "management/servicewatch",
      "enabled": false,
      "_note": "composed by regression/scenarios/composer.py — targets: alert — wave5 (owner 2026-06-13): alert policy lifecycle with ids discovered via sw-metric-catalog (createalert/showalert/setalert/setalertactivated/setalertdescription/deletebulkalerts); model notes in knowledge/formal/resources/management__servicewatch.yaml",
      "steps": [
        {
          "name": "create-sw-metric-catalog",
          "service": "servicewatch",
          "method": "POST",
          "path": "/v1/metrics",
          "json": {},
          "expect_status": [
            200,
            201,
            202
          ],
          "capture": {
            "namespace_id": "$.namespaces[0].id",
            "namespace_name": "$.namespaces[0].name",
            "metric_id": "$.namespaces[0].dimensions[0].metrics[0].id",
            "metric_name": "$.namespaces[0].dimensions[0].metrics[0].name"
          }
        },
        {
          "name": "create-alert",
          "service": "servicewatch",
          "method": "POST",
          "path": "/v1/alerts",
          "json": {
            "description": "regr alert {unique}",
            "evaluation_count": 3,
            "level": "HIGH",
            "lower_bound": 80.0,
            "metric_id": "{metric_id}",
            "missing_data_option": "BREACHING",
            "name": "regralert{unique}",
            "namespace_id": "{namespace_id}",
            "operator": "RANGE",
            "period": 300,
            "recipient_ids": [],
            "statistic": "AVG",
            "tags": [],
            "upper_bound": 90.0,
            "violation_count": 2
          },
          "expect_status": [
            200,
            201,
            202
          ],
          "capture": {
            "alert_id": "$.id"
          },
          "cleanup": {
            "method": "DELETE",
            "path": "/v1/alerts",
            "json": {
              "ids": [
                "{alert_id}"
              ]
            },
            "service": "servicewatch"
          }
        },
        {
          "name": "verify-alert-read",
          "service": "servicewatch",
          "method": "GET",
          "path": "/v1/alerts/{alert_id}",
          "expect_status": [
            200
          ]
        },
        {
          "name": "verify-alert-set",
          "service": "servicewatch",
          "method": "PATCH",
          "path": "/v1/alerts/{alert_id}",
          "json": {
            "evaluation_count": 3,
            "level": "HIGH",
            "lower_bound": 80.0,
            "metric_id": "{metric_id}",
            "missing_data_option": "BREACHING",
            "namespace_id": "{namespace_id}",
            "operator": "RANGE",
            "period": 300,
            "statistic": "AVG",
            "upper_bound": 90.0,
            "violation_count": 2
          },
          "expect_status": [
            200
          ]
        },
        {
          "name": "verify-alert-set-activated",
          "service": "servicewatch",
          "method": "PATCH",
          "path": "/v1/alerts/{alert_id}/activated",
          "json": {
            "activated_yn": "N"
          },
          "expect_status": [
            200
          ]
        },
        {
          "name": "verify-alert-set-description",
          "service": "servicewatch",
          "method": "PATCH",
          "path": "/v1/alerts/{alert_id}/description",
          "json": {
            "description": "regr alert {unique} updated"
          },
          "expect_status": [
            200
          ]
        },
        {
          "name": "delete-alert",
          "service": "servicewatch",
          "method": "DELETE",
          "path": "/v1/alerts",
          "expect_status": [
            200,
            202,
            204
          ],
          "destructive": true,
          "json": {
            "ids": [
              "{alert_id}"
            ]
          }
        }
      ],
      "_disabled_reason": "run 27452095757: create-alert 400 'At least one dimension must be set' — alert는 dimension 필수인데 sw-metric-catalog lookup이 dimension(key/value)을 잡지 못함. 중첩 배열 dimension capture 지원(composer/engine 확장) 후 활성. alert 노드는 유지"
    },
