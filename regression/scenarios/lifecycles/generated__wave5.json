    {
      "id": "gen-wave5-swatch-custom-metric",
      "service": "management/servicewatch",
      "enabled": true,
      "_note": "composed by regression/scenarios/composer.py — targets: sw-custom-metric-meta — wave5 (owner 2026-06-13): custom metric meta + OTLP ingest + data readback (createcustommetricmetas/createcustommetrics; fixed names — custom metrics have no delete API and bill past 10/month); model notes in knowledge/formal/resources/management__servicewatch.yaml || run 27452095757: ingest [202,400] (OTLP namespace routing TBD)",
      "steps": [
        {
          "name": "create-sw-custom-metric-meta",
          "service": "servicewatch",
          "method": "POST",
          "path": "/v1/metrics/custom/meta",
          "json": {
            "metricMetas": [
              {
                "descriptionEn": "regression custom metric probe",
                "descriptionKo": "회귀 커스텀 지표 프로브",
                "dimensions": [
                  [
                    "resource_id"
                  ]
                ],
                "metricName": "Custom_regr_probe_count",
                "storageResolution": 60,
                "unit": "Count"
              }
            ],
            "namespace": "MyCustom/regr"
          },
          "expect_status": [
            200,
            201,
            202
          ]
        },
        {
          "name": "verify-sw-custom-metric-meta-ingest",
          "service": "servicewatch",
          "method": "POST",
          "path": "/v1/metrics/custom",
          "json": {
            "resource_metrics": [
              {
                "resource": {
                  "attributes": [
                    {
                      "key": "namespace",
                      "value": {
                        "string_value": "MyCustom/regr"
                      }
                    }
                  ]
                },
                "scope_metrics": [
                  {
                    "scope": {
                      "name": "ServiceWatch-Agent",
                      "version": "1.0.0"
                    },
                    "metrics": [
                      {
                        "name": "Custom_regr_probe_count",
                        "description": "regression custom metric probe",
                        "unit": "Count",
                        "gauge": {
                          "data_points": [
                            {
                              "as_int": 1,
                              "attributes": [
                                {
                                  "key": "resource_id",
                                  "value": {
                                    "string_value": "regr-probe"
                                  }
                                }
                              ],
                              "time_unix_nano": 1780272000000000000
                            }
                          ]
                        }
                      }
                    ]
                  }
                ]
              }
            ]
          },
          "expect_status": [
            202,
            400
          ]
        },
        {
          "name": "verify-sw-custom-metric-meta-data-readback",
          "service": "servicewatch",
          "method": "POST",
          "path": "/v1/metrics/data",
          "json": {
            "start": 1780271700,
            "end": 1780272900,
            "period": 300,
            "statistic_type": "AVG",
            "metrics": [
              {
                "name": "Custom_regr_probe_count",
                "namespace_name": "MyCustom/regr",
                "dimensions": []
              }
            ]
          },
          "expect_status": [
            200
          ]
        }
      ]
    },
