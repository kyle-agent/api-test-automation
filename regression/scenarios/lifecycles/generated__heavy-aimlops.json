            404,
            409,
            422
          ],
          "optional": true,
          "group": "aimlops-precond"
        },
        {
          "name": "aimlops-validate-resources",
          "method": "GET",
          "path": "/v1/aimlops-platform/clusters/{cluster_id}/validate-resources",
          "expect_status": [
            200,
            400,
            403,
            404,
            409,
            422
          ],
          "optional": true,
          "group": "aimlops-precond"
        },
        {
          "name": "aimlops-internal-nodes",
