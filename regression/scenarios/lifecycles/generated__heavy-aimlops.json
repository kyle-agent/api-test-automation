            "tags": []
          },
          "expect_status": [
            200,
            201,
            202
          ],
          "capture": {
            "sg_id": "$.security_group.id"
          },
          "cleanup": {
            "method": "DELETE",
            "path": "/v1/security-groups/{sg_id}",
