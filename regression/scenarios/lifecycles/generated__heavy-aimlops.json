          "path": "/v1/aimlops-platform/internal/clusters/{cluster_id}/nodes",
          "expect_status": [
            200,
            400,
            403,
            404,
            409,
            422
          ],
          "optional": true,
          "group": "aimlops-precond"
        },
        {
          "name": "aimlops-internal-storageclasses",
