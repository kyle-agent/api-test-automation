          "method": "GET",
          "path": "/v1/server-types",
          "expect_status": [
            200,
            201,
            202
          ],
          "capture": {
            "server_type_id": {
              "list": "$.server_types",
              "where_prefix": {
                "id": "s"
              },
              "where_not_prefix": {
                "id": "g"
