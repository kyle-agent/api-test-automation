    {
      "id": "vpc-subnet-vip-nat",
      "service": "networking/vpc",
      "enabled": true,
      "heavy": true,
      "_note": "Closes the subnet-VIP NAT children (4 writes): POST/DELETE /v1/subnets/{subnet_id}/vips/{vip_id}/connected-ports, POST/DELETE .../static-nat-ips. (The VIP itself POST/PUT/DELETE is already covered elsewhere.) Adopts the shared VPC, creates an own subnet, then a VIP under it (create from data/api_bodies.json networking/vpc/createsubnetvip -> $.vip.id UNPROVEN), then exercises connected-ports (createsubnetvipport: needs a real port_id -> {unique} placeholder) and static-nat-ips (createsubnetvipnatip: needs a real publicip_id -> {unique} placeholder). All VIP-child steps optional+grouped+broad expect_status so they record coverage even on 4xx. connected_port_id / static_nat_id captures are soft (envelopes UNPROVEN). heavy:true (real VPC fallback).",
      "steps": [
        {
          "name": "create-vpc",
          "service": "vpc",
          "method": "POST",
          "path": "/v1/vpcs",
          "json": {
            "name": "regrvpc{unique}",
            "description": "API regression vip-nat",
            "cidr": "10.132.0.0/20",
            "tags": []
          },
          "expect_status": [200, 201, 202],
          "capture": {"vpc_id": "$.vpc.id"},
          "cleanup": {"method": "DELETE", "path": "/v1/vpcs/{vpc_id}", "service": "vpc"}
        },
        {
          "name": "wait-vpc",
          "service": "vpc",
          "method": "GET",
          "path": "/v1/vpcs/{vpc_id}",
          "expect_status": [200],
          "poll": {"field": "$.vpc.state", "until": ["ACTIVE"], "timeout": 180, "interval": 10}
        },
        {
          "name": "create-subnet",
          "service": "vpc",
          "method": "POST",
          "path": "/v1/subnets",
          "json": {
            "name": "regrsub{unique}",
            "description": "API regression vip-nat",
            "cidr": "10.132.9.0/24",
            "type": "GENERAL",
            "vpc_id": "{vpc_id}",
            "tags": []
          },
          "expect_status": [200, 201, 202],
          "capture": {"subnet_id": "$.subnet.id"},
          "cleanup": {"method": "DELETE", "path": "/v1/subnets/{subnet_id}", "service": "vpc"}
        },
        {
          "name": "wait-subnet",
          "service": "vpc",
          "method": "GET",
          "path": "/v1/subnets/{subnet_id}",
