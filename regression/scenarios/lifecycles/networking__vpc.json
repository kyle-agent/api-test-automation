          "json": {
            "description": "API regression subnet vip",
            "virtual_ip_address": "10.132.9.6"
          },
          "expect_status": [200, 201, 202, 400, 403, 404, 409, 422],
          "capture": {"vip_id": "$.vip.id"},
          "cleanup": {"method": "DELETE", "path": "/v1/subnets/{subnet_id}/vips/{vip_id}", "service": "vpc"}
        },
        {
          "name": "create-vip-connected-port",
          "service": "vpc",
          "method": "POST",
          "path": "/v1/subnets/{subnet_id}/vips/{vip_id}/connected-ports",
