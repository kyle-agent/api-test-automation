{
  "lifecycles": [
    {
      "id": "parallel-filestorage-capacity-restore",
      "service": "storage/parallel-filestorage",
      "enabled": false,
      "heavy": true,
      "_note": "Parallel FileStorage CAPACITY + SNAPSHOT-RESTORE lifecycle (billable parallel volume -> heavy, gated by SCP_RUN_HEAVY). Closes the 2 remaining write gaps: PUT /v1/volumes/{volume_id}/capacity and PUT /v1/snapshots/{snapshot_id}/restore. Flow: create a parallel volume (VolumeCreateRequest: name pattern ^[a-z]([a-z0-9_]){2,20}$, capacity_tb min 1, tags) -> capture $.id (Volume.id) -> set-capacity (VolumeCapacityRequest capacity_tb, min 1 max 1000 -> we send 2 to exercise a grow) -> create snapshot (capture $.snapshot.id from SnapshotCreateResponse.snapshot.id) -> restore snapshot (empty body) -> tear down snapshot + volume. Volume create/snapshot create/delete are already covered by an existing parallel-filestorage scenario surface; here they are the anchors required to reach the two uncovered PUTs. capacity_tb of 1 TB is the documented minimum; this is BILLABLE -> heavy. Bodies from data/api_docs.json model schemas; provenance DOCS-ONLY (no live 2xx). All steps optional+grouped so a failing family is isolated.",
      "steps": [
        {
          "name": "create-volume",
          "method": "POST",
          "path": "/v1/volumes",
          "optional": true,
          "json": {
            "name": "regrpfs{ualpha}",
            "capacity_tb": 1,
            "tags": []
          },
          "expect_status": [
            200,
            201,
            202,
            400,
            403,
            404,
            409,
            422
          ],
          "capture": {
            "volume_id": "$.id"
          },
          "cleanup": {
            "method": "DELETE",
            "path": "/v1/volumes/{volume_id}",
            "service": "parallel-filestorage"
          }
        },
        {
          "name": "wait-volume-available",
          "method": "GET",
          "path": "/v1/volumes/{volume_id}",
          "optional": true,
          "expect_status": [
            200,
            404
          ],
          "poll": {
            "field": "$.state",
            "until": [
              "available",
              "AVAILABLE",
              "ACTIVE"
            ],
            "timeout": 300,
            "interval": 15
          }
        },
        {
          "name": "set-volume-capacity",
          "method": "PUT",
          "path": "/v1/volumes/{volume_id}/capacity",
          "group": "pfs-capacity",
          "optional": true,
          "json": {
            "capacity_tb": 2
          },
          "expect_status": [
            200,
            201,
            202,
            400,
            403,
            404,
            409,
            422
          ]
        },
        {
          "name": "create-snapshot",
          "method": "POST",
          "path": "/v1/snapshots",
          "group": "pfs-snapshot",
          "optional": true,
          "json": {
            "volume_id": "{volume_id}"
          },
          "expect_status": [
            200,
            201,
            202,
            400,
            403,
            404,
            409,
            422
          ],
          "capture": {
            "snapshot_id": "$.snapshot.id"
          },
          "cleanup": {
            "method": "DELETE",
            "path": "/v1/snapshots/{snapshot_id}",
            "service": "parallel-filestorage"
          }
        },
        {
          "name": "restore-snapshot",
          "method": "PUT",
          "path": "/v1/snapshots/{snapshot_id}/restore",
          "group": "pfs-snapshot",
          "optional": true,
          "json": {},
          "expect_status": [
            200,
            201,
            202,
            400,
            403,
            404,
            409,
            422
          ]
        },
        {
          "name": "probe-reads",
          "probe_reads": {
            "volume_id": "{volume_id}"
          }
        },
        {
          "name": "delete-snapshot",
          "method": "DELETE",
          "path": "/v1/snapshots/{snapshot_id}",
          "group": "pfs-snapshot",
          "optional": true,
          "destructive": true,
          "expect_status": [
            200,
            202,
            204,
            404,
            409,
            400,
            403,
            422
          ],
          "retry_on_status": [
            409,
            500
          ],
          "retries": 4,
          "retry_interval": 15
        },
        {
          "name": "delete-volume",
          "method": "DELETE",
          "path": "/v1/volumes/{volume_id}",
          "optional": true,
          "destructive": true,
          "expect_status": [
            200,
            202,
            204,
            404,
            409
          ],
          "retry_on_status": [
            409,
            500
          ],
          "retries": 6,
          "retry_interval": 20
        },
        {
          "name": "wait-volume-gone",
          "method": "GET",
          "path": "/v1/volumes/{volume_id}",
          "optional": true,
          "expect_status": [
            200,
            404
          ],
          "poll": {
            "until_status": [
              404
            ],
            "timeout": 300,
            "interval": 15
          }
        }
      ],
      "_disabled_reason": "Parallel File Storage 쓰기는 테스트 대상 제외 (owner 2026-06-12) — 읽기 GET만 smoke로 커버"
    }
  ]
}
