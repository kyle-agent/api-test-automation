      "name": "regrvpc{unique}",
      "description": "API regression suite",
      "cidr": "10.160.0.0/20",
      "tags": []
     },
     "expect_status": [
      200,
      201,
      202
     ],
     "capture": {
      "vpc_id": "$.vpc.id"
     },
     "cleanup": {
      "method": "DELETE",
      "path": "/v1/vpcs/{vpc_id}",
      "service": "vpc"
     }
    },
    {
     "name": "wait-vpc",
     "service": "vpc",
     "method": "GET",
     "path": "/v1/vpcs/{vpc_id}",
     "expect_status": [
      200
     ],
     "poll": {
      "field": "$.vpc.state",
      "until": [
       "ACTIVE"
      ],
      "timeout": 180,
      "interval": 10
     }
    },
    {
