{
  "lifecycles": [
    {
      "id": "servicewatch-alert",
      "service": "management/servicewatch",
      "enabled": true,
      "_note": "Observability alert lifecycle: create alert -> read it -> PATCH full body / activated / description -> bulk-delete. Body grounded from data/api_bodies.json management/servicewatch/createalert (+setalert/setalertactivated/setalertdescription). UNPROVEN: create response envelope ($.alert.id assumed; capture-soft -> dependent steps skip if absent), and the create likely 4xx without real metric_id/namespace_id/recipient_ids — so the whole create is optional+grouped so a 4xx records coverage for POST /v1/alerts and cleanly skips the PATCH/DELETE steps without failing the lifecycle. DELETE /v1/alerts (deletebulkalerts) assumed to take {ids:[...]} mirroring deleteloggroups; unproven.",
      "steps": [
        {
          "name": "create-alert",
          "method": "POST",
          "path": "/v1/alerts",
          "group": "alert",
          "optional": true,
          "json": {
            "description": "regr alert {unique}",
            "dimension": {
              "key": "InstanceId",
              "value": "10bf5d24-0f20-4066-bb0b-de2b1d6ff502"
            },
            "dimensions": [],
            "evaluation_count": 3,
            "individual_items": [
              {
                "key": "VolumeID",
                "value": "45fbde15-cdd2-4891-be31-4a9de75fccda"
              }
            ],
            "level": "HIGH",
            "lower_bound": 80.0,
            "metric_id": "d91097ac-0387-4e69-adb2-7b8d453b8db5",
            "missing_data_option": "BREACHING",
            "name": "regralert{unique}",
            "namespace_id": "d583a229-9766-4eb8-96c4-ec389902ba3d",
            "operator": "RANGE",
            "period": 300,
            "recipient_ids": [],
            "statistic": "AVG",
            "tags": [],
            "threshold": 80.0,
            "upper_bound": 90.0,
            "violation_count": 2
          },
          "expect_status": [200, 201, 202, 400, 403, 404, 409, 422],
          "capture": {
            "alert_id": "$.alert.id"
          },
          "cleanup": {
            "method": "DELETE",
            "path": "/v1/alerts",
            "service": "servicewatch",
            "json": {
              "ids": ["{alert_id}"]
            }
          }
        },
        {
          "name": "get-alert",
          "method": "GET",
          "path": "/v1/alerts/{alert_id}",
          "group": "alert",
          "optional": true,
          "expect_status": [200, 403, 404]
        },
        {
          "name": "set-alert",
          "method": "PATCH",
          "path": "/v1/alerts/{alert_id}",
          "group": "alert",
          "optional": true,
          "json": {
            "dimension": {
              "key": "InstanceId",
              "value": "10bf5d24-0f20-4066-bb0b-de2b1d6ff502"
            },
            "dimensions": [],
            "evaluation_count": 3,
            "individual_items": [
              {
                "key": "VolumeID",
                "value": "45fbde15-cdd2-4891-be31-4a9de75fccda"
              }
            ],
            "level": "HIGH",
            "lower_bound": 80.0,
            "metric_id": "d91097ac-0387-4e69-adb2-7b8d453b8db5",
            "missing_data_option": "BREACHING",
            "namespace_id": "d583a229-9766-4eb8-96c4-ec389902ba3d",
            "operator": "RANGE",
            "period": 300,
            "statistic": "AVG",
            "threshold": 80.0,
            "upper_bound": 90.0,
            "violation_count": 2
          },
          "expect_status": [200, 201, 202, 400, 403, 404, 409, 422]
        },
        {
          "name": "set-alert-activated",
          "method": "PATCH",
          "path": "/v1/alerts/{alert_id}/activated",
          "group": "alert",
          "optional": true,
          "json": {
            "activated_yn": "Y"
          },
          "expect_status": [200, 201, 202, 400, 403, 404, 409, 422]
        },
        {
          "name": "set-alert-description",
          "method": "PATCH",
          "path": "/v1/alerts/{alert_id}/description",
          "group": "alert",
          "optional": true,
          "json": {
            "description": "regr alert {unique} updated"
          },
          "expect_status": [200, 201, 202, 400, 403, 404, 409, 422]
        },
        {
          "name": "delete-alert",
          "method": "DELETE",
          "path": "/v1/alerts",
          "group": "alert",
          "optional": true,
          "destructive": true,
          "json": {
            "ids": ["{alert_id}"]
          },
          "expect_status": [200, 201, 202, 204, 400, 403, 404, 409, 422]
        }
      ]
    },
    {
      "id": "servicewatch-dashboard",
      "service": "management/servicewatch",
      "enabled": true,
      "_note": "Dashboard lifecycle: create -> read -> PUT update -> bulk-delete. Body grounded from data/api_bodies.json management/servicewatch/createdashboard (+setdashboard). UNPROVEN: create response envelope ($.dashboard.id assumed). Create is optional+grouped so a 4xx still records POST /v1/dashboards coverage and skips dependents. DELETE /v1/dashboards (deletebulkdashboards) assumed {ids:[...]}; unproven.",
      "steps": [
        {
          "name": "create-dashboard",
          "method": "POST",
          "path": "/v1/dashboards",
          "group": "dashboard",
          "optional": true,
          "json": {
            "name": "regrdash{unique}",
            "widgets": [
              {
                "height": 1,
                "order": 1,
                "properties": {
                  "metrics": [
                    {
                      "color": "#ff7f0e",
                      "dimensions": [
                        {
                          "key": "InstanceId",
                          "value": "10bf5d24-0f20-4066-bb0b-de2b1d6ff502"
                        }
                      ],
                      "display_name": "EC2-Prod-CPU",
                      "individual_items": [
                        {
                          "key": "BucketId",
                          "value": "b-1234567890abcdef0"
                        }
                      ],
                      "name": "CPUUtilization",
                      "namespace_name": "Virtual Server",
                      "period": 300,
                      "statistic_type": "AVG"
                    }
                  ],
                  "period": 300,
                  "stacked": false,
                  "statistic_type": "AVG",
                  "title": "Virtual Server | CPU Utilization",
                  "view": "line"
                },
                "type": "metric",
                "width": 1
              }
            ]
          },
          "expect_status": [200, 201, 202, 400, 403, 404, 409, 422],
          "capture": {
            "dashboard_id": "$.dashboard.id"
          },
          "cleanup": {
            "method": "DELETE",
            "path": "/v1/dashboards",
            "service": "servicewatch",
            "json": {
              "ids": ["{dashboard_id}"]
            }
          }
        },
        {
          "name": "get-dashboard",
          "method": "GET",
          "path": "/v1/dashboards/{dashboard_id}",
          "group": "dashboard",
          "optional": true,
          "expect_status": [200, 403, 404]
        },
        {
          "name": "set-dashboard",
          "method": "PUT",
          "path": "/v1/dashboards/{dashboard_id}",
          "group": "dashboard",
          "optional": true,
          "json": {
            "name": "regrdash{unique}-renamed",
            "widgets": [
              {
                "height": 1,
                "order": 1,
                "properties": {
                  "metrics": [
                    {
                      "color": "#ff7f0e",
                      "dimensions": [
                        {
                          "key": "InstanceId",
                          "value": "10bf5d24-0f20-4066-bb0b-de2b1d6ff502"
                        }
                      ],
                      "display_name": "EC2-Prod-CPU",
                      "individual_items": [
                        {
                          "key": "BucketId",
                          "value": "b-1234567890abcdef0"
                        }
                      ],
                      "name": "CPUUtilization",
                      "namespace_name": "Virtual Server",
                      "period": 300,
                      "statistic_type": "AVG"
                    }
                  ],
                  "period": 300,
                  "stacked": false,
                  "statistic_type": "AVG",
                  "title": "Virtual Server | CPU Utilization",
                  "view": "line"
                },
                "type": "metric",
                "width": 1
              }
            ]
          },
          "expect_status": [200, 201, 202, 400, 403, 404, 409, 422]
        },
        {
          "name": "delete-dashboard",
          "method": "DELETE",
          "path": "/v1/dashboards",
          "group": "dashboard",
          "optional": true,
          "destructive": true,
          "json": {
            "ids": ["{dashboard_id}"]
          },
          "expect_status": [200, 201, 202, 204, 400, 403, 404, 409, 422]
        }
      ]
    },
    {
      "id": "servicewatch-event-rule",
      "service": "management/servicewatch",
      "enabled": true,
      "_note": "Event-rule lifecycle: create -> read -> PATCH update -> bulk-delete. Body grounded from data/api_bodies.json management/servicewatch/createeventrule (+seteventrule). event_ids/recipient_ids/resource_type_id/service_id/srn_list are sample ids from the doc body, so create likely 4xx in this account — create is optional+grouped so a 4xx still records POST /v1/event-rules coverage and skips dependents. UNPROVEN: create response envelope ($.event_rule.id assumed). DELETE /v1/event-rules (deleteeventrules) assumed {ids:[...]}; unproven.",
      "steps": [
        {
          "name": "create-event-rule",
          "method": "POST",
          "path": "/v1/event-rules",
          "group": "event-rule",
          "optional": true,
          "json": {
            "description": "regr event rule {unique}",
            "event_ids": [
              "014cb88ca2a9420e840d5c9ac16cac89",
              "28520cbbc8c54a3f86f513a9695e6481"
            ],
            "name": "regrevtrule{unique}",
            "recipient_ids": [],
            "resource_type_id": "596bf16709e84e27b7df397bf59b877c",
