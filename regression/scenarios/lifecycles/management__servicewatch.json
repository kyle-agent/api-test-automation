            "srn_list": [],
            "tags": []
          },
          "expect_status": [200, 201, 202, 400, 403, 404, 409, 422],
          "capture": {
            "event_rule_id": "$.event_rule.id"
          },
          "cleanup": {
            "method": "DELETE",
            "path": "/v1/event-rules",
