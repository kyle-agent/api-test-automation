        }
      ]
    },
    {
      "id": "servicewatch-custom-ingest",
      "service": "management/servicewatch",
      "enabled": true,
      "_note": "Light ingest-only coverage for the remaining servicewatch write endpoints that POST data rather than create addressable resources (no capture / no teardown needed): custom metrics + metric meta (OTLP-shaped), metric-data chart image render, custom log-stream collect, and OTLP log-events ingestion. All bodies grounded from data/api_bodies.json (createcustommetrics, createcustommetricmetas, downloadmetricdataimage, createcustomlogstream, createcustomlogevents). Each step is optional + its own group with a broad expect_status so a 4xx/empty-payload rejection still records coverage for the endpoint without failing the lifecycle. The OTLP-attribute sample bodies carry empty-string fields straight from the doc and are likely rejected at runtime — coverage is recorded on the call regardless.",
      "steps": [
        {
          "name": "create-custom-metrics",
          "method": "POST",
          "path": "/v1/metrics/custom",
          "group": "custom-metrics",
          "optional": true,
          "json": {
            "resource_metrics": [
              {
                "resource": {
                  "attributes": [
                    {
                      "key": "service.name",
                      "value": {
                        "string_value": "regr{unique}"
                      }
                    }
                  ]
                },
                "scope_metrics": [
                  {
                    "metrics": [
                      {
                        "description": "regression custom metric",
                        "gauge": {
                          "data_points": [
                            {
                              "as_double": 0.75,
                              "time_unix_nano": "1753776789854000000"
                            }
                          ]
                        },
                        "name": "regr_custom_metric_{unique}",
                        "unit": "Bytes"
                      }
                    ],
                    "scope": {
                      "name": "ServiceWatch-Agent",
                      "version": "1.0.0"
                    }
                  }
                ]
              }
            ]
          },
          "expect_status": [200, 201, 202, 204, 400, 403, 404, 409, 422]
        },
        {
          "name": "create-custom-metric-meta",
          "method": "POST",
          "path": "/v1/metrics/custom/meta",
          "group": "custom-metric-meta",
          "optional": true,
          "json": {
            "metricMetas": [
              {
                "descriptionEn": "regression custom metric meta",
                "descriptionKo": "regression custom metric meta",
                "dimensions": [
                  ["image_id"]
                ],
                "metricName": "Custom_regr_{unique}",
                "storageResolution": 60,
                "unit": "Bytes"
              }
            ],
            "namespace": "MyCustom/regr{unique}"
          },
          "expect_status": [200, 201, 202, 204, 400, 403, 404, 409, 422]
        },
        {
          "name": "download-metric-data-image",
          "method": "POST",
          "path": "/v1/metrics/data/download/image",
          "group": "metric-image",
          "optional": true,
          "json": {
            "end": 1640995440,
            "height": 400,
            "metrics": [
              {
                "color": "#0000ff",
                "dimensions": [
                  {
                    "key": "VolumeID",
                    "value": "45fbde15-cdd2-4891-be31-4a9de75fccda"
                  }
                ],
                "display_name": "regr{unique}",
                "name": "CPU Usage/Core[Basic]",
                "namespace_name": "Virtual Server",
                "period": 300,
                "statistic_type": "AVG"
              }
            ],
            "period": 300,
            "start": 1640995200,
            "statistic_type": "AVG",
            "timezone": "UTC",
            "title": "regr{unique} chart",
            "width": 600
          },
          "expect_status": [200, 201, 202, 204, 400, 403, 404, 409, 422]
        },
        {
          "name": "create-custom-log-stream",
          "method": "POST",
          "path": "/v1/log-groups/log-streams/collect/custom",
          "group": "custom-log-stream",
          "optional": true,
          "json": {
            "log_group_name": "regrlg{unique}",
            "log_stream_name": "regrls{unique}"
          },
          "expect_status": [200, 201, 202, 204, 400, 403, 404, 409, 422]
        },
        {
          "name": "create-custom-log-events",
          "method": "POST",
          "path": "/v1/log-groups/log-streams/log-events",
          "group": "custom-log-events",
          "optional": true,
          "json": {
            "resourceLogs": [
              {
                "resource": {
                  "attributes": [
                    {
                      "key": "account_id",
                      "value": {
                        "stringValue": "regr{unique}"
                      }
                    }
                  ]
                },
                "scopeLogs": [
                  {
                    "logRecords": [
                      {
                        "body": {
                          "stringValue": "level=info regression otlp test log {unique}"
                        },
                        "timeUnixNano": "1762336464000000000"
                      }
                    ]
                  }
                ]
              }
            ]
          },
          "expect_status": [200, 201, 202, 204, 400, 403, 404, 409, 422]
        }
      ]
    }
  ]
}
