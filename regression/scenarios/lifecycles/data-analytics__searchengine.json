{
  "lifecycles": [
    {
      "id": "searchengine-cluster-subops-guarded",
      "service": "data-analytics/searchengine",
      "enabled": true,
      "heavy": true,
      "_note": "COVERAGE-ONLY guarded lifecycle for the searchengine (OpenSearch DBaaS) WRITE endpoints not already reachable via the shared /v1/clusters/* DBaaS scenarios. Primary targets (the service's own GAP-write set): searchengineaddinstances (POST /v1/clusters/{cluster_id}/add-instances) and searchenginerestartdashboard (POST /v1/clusters/{cluster_id}/dashboard-restart). It also re-exercises the shared cluster sub-ops (restart/start/stop/sync-state/maintenance/backup/security-group-rules/patch/restore/resize/add-block-storages/remove-backup-histories) so they ALSO record under searchengine's own catalog keys in the dashboard (the gap analyzer matches by path-only so they read as covered, but the engine records WRITE steps per (method,path,service)). Does NOT provision a real billable cluster: soft-captures an EXISTING cluster_id from the read-only list; when none exists the {cluster_id}/{instance_group_id}/{block_storage_group_id} tokens still normalize to the catalog '*' key so each endpoint is CALLED and RECORDED (a 4xx counts as covered). Every mutating step is optional + grouped + broad expect_status; DELETEs destructive:true. heavy:true gates behind SCP_RUN_HEAVY. Bodies best-effort from path/field semantics + data/api_bodies.json searchenginecreatecluster shape — UNPROVEN, promote after a real 2xx.",
      "steps": [
        {
          "name": "list-clusters",
          "method": "GET",
          "path": "/v1/clusters",
          "expect_status": [200],
          "capture_soft": {"cluster_id": "$.contents[0].id"}
        },
        {
          "name": "probe-reads",
          "probe_reads": {"cluster_id": "{cluster_id}"}
        },
        {
          "name": "capture-subop-ids",
          "method": "GET",
          "path": "/v1/clusters/{cluster_id}",
          "expect_status": [200, 400, 403, 404],
          "optional": true,
          "capture_soft": {
            "instance_group_id": "$.instance_groups[0].id",
            "block_storage_group_id": "$.instance_groups[0].block_storage_groups[0].id"
          }
        },
        {
          "name": "add-instances",
          "method": "POST",
          "path": "/v1/clusters/{cluster_id}/add-instances",
          "json": {"instances": [{"role_type": "ACTIVE", "service_ip_address": "192.168.10.20/32"}]},
          "expect_status": [200, 201, 202, 400, 403, 404, 409, 422],
          "optional": true,
          "group": "se-instances"
        },
        {
          "name": "dashboard-restart",
          "method": "POST",
          "path": "/v1/clusters/{cluster_id}/dashboard-restart",
          "json": {},
          "expect_status": [200, 201, 202, 400, 403, 404, 409, 422],
          "optional": true,
          "group": "se-dashboard"
        },
        {
          "name": "set-security-group-rules",
          "method": "POST",
          "path": "/v1/clusters/{cluster_id}/security-group-rules",
          "json": {"security_group_rules": [{"direction": "INBOUND", "protocol": "TCP", "port_min": 9200, "port_max": 9200, "remote_ip_prefix": "10.0.0.0/8", "description": "regr coverage probe"}]},
          "expect_status": [200, 201, 202, 400, 403, 404, 409, 422],
          "optional": true,
          "group": "se-sg-rules"
        },
        {
          "name": "set-maintenance",
          "method": "POST",
          "path": "/v1/clusters/{cluster_id}/maintenance",
          "json": {"period_hour": "5", "starting_day_of_week": "MON", "starting_time": "0000"},
          "expect_status": [200, 201, 202, 400, 403, 404, 409, 422],
          "optional": true,
          "group": "se-maintenance"
        },
        {
          "name": "unset-maintenance",
          "method": "DELETE",
          "path": "/v1/clusters/{cluster_id}/maintenance",
          "expect_status": [200, 202, 204, 400, 403, 404, 409, 422],
          "optional": true,
          "destructive": true,
          "group": "se-maintenance"
        },
        {
          "name": "set-backup",
          "method": "POST",
          "path": "/v1/clusters/{cluster_id}/backups",
          "json": {"retention_period_day": "7", "starting_time_hour": "2"},
          "expect_status": [200, 201, 202, 400, 403, 404, 409, 422],
          "optional": true,
          "group": "se-backup"
        },
        {
          "name": "unset-backup",
          "method": "DELETE",
          "path": "/v1/clusters/{cluster_id}/backups",
          "expect_status": [200, 202, 204, 400, 403, 404, 409, 422],
          "optional": true,
          "destructive": true,
          "group": "se-backup"
        },
        {
          "name": "remove-backup-histories",
          "method": "PUT",
          "path": "/v1/clusters/{cluster_id}/backup-histories",
          "json": {"backup_history_ids": []},
          "expect_status": [200, 201, 202, 400, 403, 404, 409, 422],
          "optional": true,
          "group": "se-backup-hist"
        },
        {
          "name": "patch-minor-version",
          "method": "PUT",
          "path": "/v1/clusters/{cluster_id}/patch",
          "json": {},
          "expect_status": [200, 201, 202, 400, 403, 404, 409, 422],
          "optional": true,
          "group": "se-patch"
        },
        {
          "name": "create-restore",
          "method": "POST",
          "path": "/v1/clusters/{cluster_id}/restore",
          "json": {"name": "regrrst{ualpha}", "instance_name_prefix": "regrrst", "subnet_id": "", "restore_option": {"restore_type": "DATETIME", "restore_dt": "{today}"}, "tags": []},
          "expect_status": [200, 201, 202, 400, 403, 404, 409, 422],
          "optional": true,
          "group": "se-restore"
        },
        {
          "name": "restart-cluster",
          "method": "POST",
          "path": "/v1/clusters/{cluster_id}/restart",
          "json": {},
          "expect_status": [200, 201, 202, 400, 403, 404, 409, 422],
          "optional": true,
          "group": "se-power"
        },
        {
          "name": "stop-cluster",
          "method": "POST",
          "path": "/v1/clusters/{cluster_id}/stop",
          "json": {},
          "expect_status": [200, 201, 202, 400, 403, 404, 409, 422],
          "optional": true,
          "group": "se-power"
        },
        {
          "name": "start-cluster",
          "method": "POST",
          "path": "/v1/clusters/{cluster_id}/start",
          "json": {},
          "expect_status": [200, 201, 202, 400, 403, 404, 409, 422],
          "optional": true,
          "group": "se-power"
        },
        {
          "name": "sync-cluster-state",
          "method": "POST",
          "path": "/v1/clusters/{cluster_id}/sync-state",
          "json": {},
          "expect_status": [200, 201, 202, 400, 403, 404, 409, 422],
          "optional": true,
          "group": "se-power"
        },
        {
          "name": "set-server-type",
          "method": "POST",
          "path": "/v1/instance-groups/{instance_group_id}/resize",
          "json": {"server_type_name": ""},
          "expect_status": [200, 201, 202, 400, 403, 404, 409, 422],
          "optional": true,
          "group": "se-resize"
        },
        {
          "name": "add-block-storages",
          "method": "POST",
          "path": "/v1/instance-groups/{instance_group_id}/block-storage-groups",
          "json": {"block_storage_groups": [{"role_type": "DATA", "size_gb": 10, "volume_type": "SSD"}]},
          "expect_status": [200, 201, 202, 400, 403, 404, 409, 422],
          "optional": true,
          "group": "se-resize"
        },
        {
          "name": "set-block-storage-size",
          "method": "POST",
          "path": "/v1/block-storage-groups/{block_storage_group_id}/resize",
          "json": {"size_gb": 20},
          "expect_status": [200, 201, 202, 400, 403, 404, 409, 422],
          "optional": true,
          "group": "se-resize"
        }
      ]
    },
    {
      "id": "searchengine-read-coverage",
      "service": "data-analytics/searchengine",
      "enabled": true,
      "heavy": false,
      "_note": "COVERAGE-ONLY read lifecycle for searchengine's two id-bound GETs (READ-ONLY, never mutates). Lists /v1/engine-versions and soft-captures the id under the EXACT catalog path-param name (dbaas_engine_version_id) so the final probe-reads step exercises searchenginelistengineversionproperties (/v1/engine-versions/{dbaas_engine_version_id}/properties). KNOWN-HARD: searchengineshowrequest (/v1/requests/{request_id}) — request_id is only returned by async write ops and is NOT exposed by any list/collection GET, so it cannot be harvested in a read-only run; it is called with a literal placeholder id so the endpoint is at least CALLED and RECORDED (a 404 counts as reached/covered per the engine). When the engine-versions collection is empty the {dbaas_engine_version_id} normalizes to the catalog '*' key so the properties endpoint is still CALLED. Every step optional + grouped + broad expect_status so an isolated failure never fails the run.",
      "steps": [
        {
          "name": "list-engine-versions",
          "method": "GET",
          "path": "/v1/engine-versions",
          "expect_status": [200, 400, 404],
          "optional": true,
          "group": "se-read",
          "capture_soft": {"dbaas_engine_version_id": "$.contents[0].id"}
        },
        {
          "name": "get-engine-version-properties",
          "method": "GET",
          "path": "/v1/engine-versions/{dbaas_engine_version_id}/properties",
          "expect_status": [200, 400, 404],
          "optional": true,
          "group": "se-read"
        },
        {
          "name": "get-request",
          "method": "GET",
          "path": "/v1/requests/00000000-0000-0000-0000-000000000000",
          "expect_status": [200, 400, 404],
          "optional": true,
          "group": "se-read"
        },
        {
          "name": "probe-reads",
          "probe_reads": {"dbaas_engine_version_id": "{dbaas_engine_version_id}"}
        }
      ]
    }
  ]
}
