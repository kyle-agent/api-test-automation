{
  "_comment": "Composed heavy verification wave — VS interface/static-NAT (owner domain knowledge 2026-06-12). Enable in an approved heavy window.",
  "lifecycles": [
    {
      "id": "gen-heavy-vs-netops",
      "service": "compute/virtualserver",
      "enabled": true,
      "_note": "extended after owner knowledge 2026-06-13: server post-create ops (lock/unlock/dump/password w/ keypair private_key), block-volume attach/detach, custom-image from RUNNING server. attach-409 retry from run 27447899572 retained.",
      "steps": [
        {
          "name": "create-keypair",
          "service": "virtualserver",
          "method": "POST",
          "path": "/v1/keypairs",
          "json": {
            "name": "regrkey{unique}",
            "tags": []
          },
          "expect_status": [
            200,
            201,
            202
          ],
          "capture": {
            "private_key": "$.private_key"
          },
          "cleanup": {
            "method": "DELETE",
            "path": "/v1/keypairs/regrkey{unique}",
            "service": "virtualserver"
          }
        },
        {
          "name": "create-image",
          "service": "virtualserver",
          "method": "GET",
          "path": "/v1/images?status=active&scp_original_image_type=standard&visibility=public&limit=50",
          "expect_status": [
            200,
            201,
            202
          ],
          "capture": {
            "image_id": "$.images[0].id"
          }
        },
        {
          "name": "create-server-type",
          "service": "virtualserver",
          "method": "GET",
          "path": "/v1/server-types",
          "expect_status": [
            200,
            201,
            202
          ],
          "capture": {
            "server_type_id": {
              "list": "$.server_types",
              "where_prefix": {
                "id": "s"
              },
              "where_not_prefix": {
                "id": "g"
              },
              "get": "id"
            }
          }
        },
        {
          "name": "create-block-volume",
          "service": "virtualserver",
          "method": "POST",
          "path": "/v1/volumes",
          "json": {
            "name": "regrvol{unique}",
            "description": "API regression suite",
            "size": 104,
            "volume_type": "SSD_Provisioned",
            "max_iops": 10000,
            "max_throughput": 500,
            "tags": []
          },
          "expect_status": [
            200,
            201,
            202
          ],
          "capture": {
            "vol_id": "$.id"
          },
          "cleanup": {
            "method": "DELETE",
            "path": "/v1/volumes/{vol_id}",
            "service": "virtualserver"
          }
        },
        {
          "name": "wait-block-volume",
          "service": "virtualserver",
          "method": "GET",
          "path": "/v1/volumes/{vol_id}",
          "expect_status": [
            200
          ],
          "poll": {
            "field": "$.state",
            "until": [
              "available",
              "AVAILABLE",
              "ACTIVE"
            ],
            "timeout": 300,
            "interval": 15
          }
        },
        {
          "name": "create-security-group",
