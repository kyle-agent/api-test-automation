{
  "lifecycles": [
    {
      "id": "security-secretsmanager-writes",
      "service": "security/secretsmanager",
      "enabled": true,
      "_note": "Secrets Manager lifecycle covering the 5 uncovered WRITE ops the existing 'security-secretsmanager-secret' template does not touch: POST /v1/secrets/kms-key, POST /v1/secrets/random-password (both standalone, no secret needed), and the per-secret writes POST /v1/secrets/{secret_id}/values (reveal a version's value), PUT /v1/secrets/{secret_id}/kmsid (re-key), PUT /v1/secrets/{secret_id}/restore (restore from the soft-delete recovery window). Bodies from data/api_bodies.json (createsecretsmanager, createkey, generaterandompassword, setkmsid, createsecretsmanagerkmskey) + data/api_docs.json (secretsmanagershowsecretvaluerequest) — _UNPROVEN past the create/get/list/delete spine the template already proved. Spine mirrors the template: create a KMS transit key (capture $.key.id, body security/kms/createkey) -> create secret with kms_id (capture $.secret.id, wait 15s for the kms key to settle, secret_value is a JSON STRING, private_acl_enabled is the STRING 'false') -> exercise the per-secret writes -> soft-delete (DELETE with body {waiting_time_ndays:7}) -> restore (PUT .../restore, valid only while in the recovery window) -> final soft-delete cleanup -> delete kms. Standalone writes (kms-key, random-password) are isolated optional+grouped (kms-key returns $.key id only when a service KMS key is provisioned; random-password just returns a generated string). Per-secret writes are grouped optional so a 4xx (e.g. re-key rejected, restore-not-deleted) isolates as a warning and still RECORDS coverage. NOTE: POST /v1/secrets/{secret_id}/values is the REVEAL endpoint (body label/version_id), distinct from the template's PUT .../values (update); 'CURRENT' is the default version label.",
      "steps": [
        {
          "name": "create-kms",
          "method": "POST",
          "path": "/v1/kms/transit",
          "service": "kms",
          "json": {
            "auto_rotate": "Y",
            "description": "API regression suite",
            "key_type": "advanced",
            "name": "regrswkms{unique}",
            "purpose": "rsa-2048",
            "rotate_cycle": 7,
            "tags": []
          },
          "expect_status": [200, 201, 202],
          "capture": {"kms_id": "$.key.id"},
          "cleanup": {
            "method": "DELETE",
            "path": "/v1/kms/transit/{kms_id}",
            "service": "kms"
          }
        },
        {
          "name": "create-kms-key",
          "service": "secretsmanager",
          "method": "POST",
          "path": "/v1/secrets/kms-key",
          "group": "xcov-sm-kms-key",
          "optional": true,
          "json": {"service_name": ""},
          "expect_status": [200, 201, 202, 400, 403, 404, 409, 422]
        },
        {
          "name": "random-password",
          "service": "secretsmanager",
          "method": "POST",
          "path": "/v1/secrets/random-password",
          "group": "xcov-sm-random-password",
          "optional": true,
          "json": {
            "exclude_characters": "abcdefg",
            "exclude_lowercase": "false",
            "exclude_numbers": "false",
            "exclude_punctuation": "false",
            "exclude_uppercase": "false",
            "include_space": "false",
            "password_length": 32,
            "require_each_included_type": "true"
          },
          "expect_status": [200, 201, 202, 400, 403, 404, 409, 422]
        },
        {
          "name": "create",
          "method": "POST",
          "path": "/v1/secrets",
          "wait": 15,
          "json": {
            "acl_cidr": "10.0.0.0/25",
            "description": "API regression suite",
            "kms_id": "{kms_id}",
            "name": "regrsecw{unique}",
            "private_acl_enabled": "false",
            "private_acl_resources": [],
            "secret_value": "{\"k\":\"v\"}",
            "tags": []
          },
          "expect_status": [200, 201, 202],
          "capture": {"secret_id": "$.secret.id"},
          "cleanup": {
            "method": "DELETE",
            "path": "/v1/secrets/{secret_id}",
            "service": "secretsmanager",
            "json": {"waiting_time_ndays": 7}
          }
        },
        {
          "name": "get",
          "method": "GET",
          "path": "/v1/secrets/{secret_id}",
          "expect_status": [200]
        },
        {
          "name": "reveal-value",
          "service": "secretsmanager",
          "method": "POST",
          "path": "/v1/secrets/{secret_id}/values",
          "group": "xcov-sm-reveal-value",
          "optional": true,
          "json": {"label": "CURRENT"},
          "expect_status": [200, 201, 202, 400, 403, 404, 409, 422]
        },
        {
          "name": "set-kmsid",
          "service": "secretsmanager",
          "method": "PUT",
          "path": "/v1/secrets/{secret_id}/kmsid",
          "group": "xcov-sm-set-kmsid",
          "optional": true,
          "json": {"kms_id": "{kms_id}"},
          "expect_status": [200, 201, 202, 400, 403, 404, 409, 422]
        },
        {
          "name": "probe-reads",
          "probe_reads": {"secret_id": "{secret_id}"}
        },
        {
          "name": "soft-delete",
          "service": "secretsmanager",
          "method": "DELETE",
          "path": "/v1/secrets/{secret_id}",
          "group": "xcov-sm-restore",
          "optional": true,
          "json": {"waiting_time_ndays": 7},
          "expect_status": [200, 201, 202, 204, 400, 403, 404, 409, 422],
          "destructive": true
        },
        {
          "name": "restore",
          "service": "secretsmanager",
          "method": "PUT",
          "path": "/v1/secrets/{secret_id}/restore",
          "group": "xcov-sm-restore",
          "optional": true,
          "json": {},
          "expect_status": [200, 201, 202, 400, 403, 404, 409, 422]
        },
        {
          "name": "delete",
          "method": "DELETE",
          "path": "/v1/secrets/{secret_id}",
          "json": {"waiting_time_ndays": 7},
          "expect_status": [200, 202, 204, 400, 404, 409],
          "destructive": true
        },
        {
          "name": "delete-kms",
          "method": "DELETE",
          "path": "/v1/kms/transit/{kms_id}",
          "service": "kms",
          "expect_status": [200, 202, 204],
          "destructive": true
        }
      ]
    }
  ]
}
