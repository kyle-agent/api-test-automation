    {
      "id": "gen-wave5-iam-saml",
      "service": "management/iam",
      "enabled": false,
      "_note": "composed verification wave 5 (iam write-family closure) — saml provider JSON experiment: doc request example is multipart/form-data with an OPTIONAL metadata file; the engine sends JSON only, so this chain probes whether the gateway accepts JSON without a file. If it 400/415s, disable and reclassify as engine-multipart-blocked. deletesamlproviders (bulk, body ids) is the only saml delete; composed by regression/scenarios/composer.py — targets: iam-saml-provider",
      "steps": [
        {
          "name": "create-iam-saml-provider",
          "service": "iam",
          "method": "POST",
          "path": "/v1/saml-providers",
          "json": {
            "federation_type": "SAML",
            "saml_provider_name": "regrsaml{ualpha}",
            "description": "API regression suite"
          },
          "expect_status": [
            200,
            201,
            202
          ],
          "capture": {
            "saml_provider_id": "$.id"
          },
          "cleanup": {
            "method": "DELETE",
            "path": "/v1/saml-providers/bulk",
            "json": {
              "ids": [
                "{saml_provider_id}"
              ]
            },
            "service": "iam"
          }
        },
        {
          "name": "verify-iam-saml-provider-show",
