    {
      "id": "gen-wave4-nlog",
      "service": "management/network-logging",
      "enabled": true,
      "_note": "real DTO is just {bucket_name, resource_type}; bucket apitest-logsink is ensured by the workflow (core/oplog.py ensure-logsink). loggable security-group variation rides later (C4)",
      "steps": [
        {
          "name": "create-network-logging-storage",
          "service": "network-logging",
          "method": "POST",
          "path": "/v1/network-logging/storages",
          "json": {
            "bucket_name": "apitest-logsink",
            "resource_type": "SECURITY_GROUP"
          },
          "expect_status": [
            200,
            201,
            202
          ],
          "capture": {
            "network_logging_storage_id": "$.network_logging_storage.id"
          },
          "cleanup": {
            "method": "DELETE",
            "path": "/v1/network-logging/storages/{network_logging_storage_id}",
            "service": "network-logging"
