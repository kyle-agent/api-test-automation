{
  "lifecycles": [
    {
      "id": "data-ops-service-and-ops-guarded",
      "service": "data-analytics/data-ops",
      "enabled": true,
      "heavy": true,
      "_note": "COVERAGE-ONLY guarded lifecycle for data-ops's uncovered WRITE endpoints: createdataopsservice (POST /v1/data-ops-services), updatedataopsservice (PUT), deletedataopsservice (DELETE), the two validate-resources POSTs (create- and update-scope), and createdataops/updatedataopsv1/deletedataopsv1 on /v1/data-ops. data-ops provisions a billable analytics cluster + service, so this is heavy:true and does NOT spin up a real cluster: it soft-captures any EXISTING service/ops id from the read-only lists; when none exist the {data_ops_service_id}/{data_ops_id}/{cluster_id} tokens still normalize to the catalog '*' key so each endpoint is CALLED and RECORDED (a 4xx counts as covered per the engine). Every mutating step is optional + grouped + broad expect_status so an isolated 4xx isolates to its group and never fails the run or chains a real create->mutate->delete. DELETEs are destructive:true (gated by SCP_ALLOW_DESTRUCTIVE). No data/api_bodies.json entries exist for data-ops, so bodies are best-effort from path/field semantics + the shared SCP analytics-console shape (mirrors data-flow which mirrors the dbaas instance_groups/block_storage shape) and are UNPROVEN — promote to validated after a real 2xx. validate-resources is a dry-run preflight the console calls before create/update.",
      "steps": [
        {
          "name": "list-data-ops-services",
          "method": "GET",
          "path": "/v1/data-ops-services",
          "expect_status": [200],
          "capture_soft": {"data_ops_service_id": "$.contents[0].id"}
        },
        {
          "name": "list-data-ops",
          "method": "GET",
          "path": "/v1/data-ops",
          "expect_status": [200],
          "capture_soft": {"data_ops_id": "$.contents[0].id"}
        },
        {
          "name": "probe-reads",
          "probe_reads": {
            "data_ops_service_id": "{data_ops_service_id}",
            "data_ops_id": "{data_ops_id}"
          }
        },
        {
          "name": "capture-cluster-id",
          "method": "GET",
          "path": "/v1/data-ops-services/{data_ops_service_id}",
          "expect_status": [200, 400, 403, 404],
          "optional": true,
          "capture_soft": {"cluster_id": "$.cluster_id"}
        },
        {
          "name": "validate-resources-create",
          "method": "POST",
          "path": "/v1/data-ops-services/clusters/{cluster_id}/validate-resources",
          "json": {"name": "regrdosvc{ualpha}", "subnet_id": "", "server_type_name": "", "instance_count": 1},
          "expect_status": [200, 201, 202, 400, 403, 404, 409, 422],
          "optional": true,
          "group": "do-validate"
        },
        {
          "name": "validate-resources-update",
          "method": "POST",
          "path": "/v1/data-ops-services/{data_ops_service_id}/validate-resources",
          "json": {"server_type_name": "", "instance_count": 1},
          "expect_status": [200, 201, 202, 400, 403, 404, 409, 422],
          "optional": true,
          "group": "do-validate"
        },
        {
          "name": "create-data-ops-service",
          "method": "POST",
          "path": "/v1/data-ops-services",
          "json": {
            "name": "regrdosvc{ualpha}",
            "description": "API regression coverage probe",
            "dbaas_engine_version_id": "",
            "subnet_id": "",
            "nat_enabled": false,
            "instance_name_prefix": "regrdo",
            "timezone": "Asia/Seoul",
            "allowable_ip_addresses": [],
            "instance_groups": [
              {
                "role_type": "ACTIVE",
                "server_type_name": "",
                "block_storage_groups": [{"role_type": "OS", "size_gb": 104, "volume_type": "SSD"}],
                "instances": [{"role_type": "ACTIVE", "service_ip_address": "192.168.10.10/32"}]
              }
            ],
            "tags": []
          },
          "expect_status": [200, 201, 202, 400, 403, 404, 409, 422],
          "optional": true,
          "group": "do-service"
        },
        {
          "name": "update-data-ops-service",
          "method": "PUT",
          "path": "/v1/data-ops-services/{data_ops_service_id}",
          "json": {"description": "API regression coverage probe (updated)"},
          "expect_status": [200, 201, 202, 400, 403, 404, 409, 422],
          "optional": true,
          "group": "do-service"
        },
        {
          "name": "delete-data-ops-service",
          "method": "DELETE",
          "path": "/v1/data-ops-services/{data_ops_service_id}",
          "expect_status": [200, 202, 204, 400, 403, 404, 409, 422],
          "optional": true,
          "destructive": true,
          "group": "do-service"
        },
        {
          "name": "create-data-ops",
          "method": "POST",
          "path": "/v1/data-ops",
          "json": {
            "name": "regrdo{ualpha}",
            "description": "API regression coverage probe",
            "data_ops_service_id": "{data_ops_service_id}",
            "tags": []
          },
          "expect_status": [200, 201, 202, 400, 403, 404, 409, 422],
          "optional": true,
          "group": "do-ops"
        },
        {
          "name": "update-data-ops",
          "method": "PUT",
          "path": "/v1/data-ops/{data_ops_id}",
          "json": {"description": "API regression coverage probe (updated)"},
          "expect_status": [200, 201, 202, 400, 403, 404, 409, 422],
          "optional": true,
          "group": "do-ops"
        },
        {
          "name": "delete-data-ops",
          "method": "DELETE",
          "path": "/v1/data-ops/{data_ops_id}",
          "expect_status": [200, 202, 204, 400, 403, 404, 409, 422],
          "optional": true,
          "destructive": true,
          "group": "do-ops"
        }
      ]
    }
  ]
}
