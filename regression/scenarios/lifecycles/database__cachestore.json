{
  "lifecycles": [
    {
      "id": "cachestore-cluster-subops-guarded",
      "service": "database/cachestore",
      "enabled": true,
      "heavy": true,
      "_note": "COVERAGE-ONLY guarded lifecycle for the cachestore (Redis) DBaaS cluster sub-op WRITE endpoints. Soft-captures an existing cluster_id (+ instance_group_id/bsg_id) from read-only calls; absent that, tokens normalize to the catalog '*' key so every endpoint is CALLED+RECORDED (4xx counts). All mutating steps optional+grouped+broad-expect_status; heavy:true (SCP_RUN_HEAVY); DELETEs destructive:true. Bodies from api_docs request_example, UNPROVEN. cachestore DIVERGES MOST from the relational template: it uses commands (PUT /commands with {id,name,new_value}) + commands/sync INSTEAD of the full archive/audit/log-export surface, has NO archive/audit-log/log-export/replicas/promote/databases/add-secondary, no add-block-storages, patch body uses dbaas_engine+software_version, backup body omits archive_frequency_minute, and restore wants explicit OS+DATA block_storage_groups.",
      "steps": [
        {
          "name": "list-clusters",
          "method": "GET",
          "path": "/v1/clusters",
          "expect_status": [
            200
          ],
          "capture_soft": {
            "cluster_id": "$.contents[0].id"
          }
        },
        {
          "name": "probe-reads",
          "probe_reads": {
            "cluster_id": "{cluster_id}"
          }
        },
        {
          "name": "capture-subop-ids",
          "method": "GET",
          "path": "/v1/clusters/{cluster_id}",
          "expect_status": [
            200,
            400,
            403,
            404
          ],
          "optional": true,
          "capture_soft": {
            "instance_group_id": "$.instance_groups[0].id",
            "bsg_id": "$.instance_groups[0].block_storage_groups[0].id"
          }
        },
        {
          "name": "set-maintenance",
          "method": "POST",
          "path": "/v1/clusters/{cluster_id}/maintenance",
          "json": {
            "start_day_of_week": "SUN",
            "start_minute": "00",
            "start_time": "03",
            "term_hour": "4"
          },
          "expect_status": [
            200,
            201,
            202,
            400,
            403,
            404,
            409,
            422
          ],
          "optional": true,
          "group": "maint"
        },
        {
          "name": "unset-maintenance",
          "method": "DELETE",
          "path": "/v1/clusters/{cluster_id}/maintenance",
          "expect_status": [
            200,
            202,
            204,
            400,
            403,
            404,
            409,
            422
          ],
          "optional": true,
          "destructive": true,
          "group": "maint"
        },
        {
          "name": "create-backup",
          "method": "POST",
          "path": "/v1/clusters/{cluster_id}/backups",
          "json": {
            "retention_period_day": "8",
            "starting_time_hour": "3"
          },
          "expect_status": [
            200,
            201,
            202,
            400,
            403,
            404,
            409,
            422
          ],
          "optional": true,
          "group": "backup"
        },
        {
          "name": "remove-backup-histories",
          "method": "PUT",
          "path": "/v1/clusters/{cluster_id}/backup-histories",
          "json": {
            "backup_history_number": []
          },
          "expect_status": [
            200,
            201,
            202,
            400,
            403,
            404,
            409,
            422
          ],
          "optional": true,
          "group": "backup"
        },
        {
          "name": "delete-backup",
          "method": "DELETE",
          "path": "/v1/clusters/{cluster_id}/backups",
          "expect_status": [
            200,
            202,
            204,
            400,
            403,
            404,
            409,
            422
          ],
          "optional": true,
          "destructive": true,
          "group": "backup"
        },
        {
          "name": "set-parameters",
          "method": "PUT",
          "path": "/v1/clusters/{cluster_id}/parameters",
          "json": {
            "parameters": [
              {
                "id": "",
                "new_value": "256",
                "old_value": ""
              }
            ]
          },
          "expect_status": [
            200,
            201,
            202,
            400,
            403,
            404,
            409,
            422
          ],
          "optional": true,
          "group": "param"
        },
        {
          "name": "sync-parameters",
