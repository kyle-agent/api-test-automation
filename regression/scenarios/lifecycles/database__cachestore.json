        {
          "name": "create-restore",
          "method": "POST",
          "path": "/v1/clusters/{cluster_id}/restore",
          "json": {
            "allowable_ip_addresses": [],
            "backup_history_number": "202501010000",
            "backup_recovery_time": "",
