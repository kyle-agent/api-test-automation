    },
    {
      "id": "gen-wave5-apigw-privatelink",
      "service": "application-service/apigateway",
      "enabled": true,
      "_note": "SELF-CONTAINED privatelink chain — enabled per the gate 'enabled only if self-contained': own vpc/subnet (10.163.0.0/20, unused block) -> networking privatelink-service with approval_type AUTO + connected_resource_type IP (no LB, no VM — UNPROVEN docs DTO, first live exercise of createprivatelinkservice) -> apigw privatelink-endpoint family on it, plus the scf privatelink-endpoint family against the SAME provider service (one infra chain; all UNPROVEN privatelink risk isolated in this one lifecycle). create/show/set/delete are the solid 2xx candidates; approve/connect/request are state-machine-dependent (AUTO approval may pre-empt them) so they ride as optional gated probes with broad expects + paired enum probes (DISCONNECT->RECONNECT, RE_REQUEST then CANCEL last) to maximise the chance one lands 2xx. scf quirks honoured: privatelink-SERVICE enable is NEVER sent (strands the function in Creating, CloudFunctionNotDeletableError — only the disable=false probe covers updateprivatelinkservice), READY re-poll between config writes and before delete.",
      "steps": [
        {
          "name": "create-vpc",
          "service": "vpc",
          "method": "POST",
          "path": "/v1/vpcs",
          "json": {
            "name": "regrw5vpc{unique}",
            "description": "API regression wave5 privatelink",
            "cidr": "10.163.0.0/20",
            "tags": []
          },
          "expect_status": [200, 201, 202],
          "capture": {
            "vpc_id": "$.vpc.id"
          },
          "cleanup": {
            "method": "DELETE",
            "path": "/v1/vpcs/{vpc_id}",
            "service": "vpc"
          },
          "adopt": "vpc"
        },
        {
          "name": "wait-vpc",
          "service": "vpc",
          "method": "GET",
          "path": "/v1/vpcs/{vpc_id}",
          "expect_status": [200],
          "poll": {
            "field": "$.vpc.state",
            "until": ["ACTIVE"],
            "timeout": 180,
            "interval": 10
          }
        },
        {
          "name": "create-subnet",
          "service": "vpc",
          "method": "POST",
          "path": "/v1/subnets",
          "json": {
            "name": "regrw5sub{unique}",
            "description": "API regression wave5 privatelink",
            "cidr": "10.163.8.0/24",
            "type": "GENERAL",
            "vpc_id": "{vpc_id}",
            "tags": []
          },
          "expect_status": [200, 201, 202],
          "capture": {
            "subnet_id": "$.subnet.id"
          },
          "cleanup": {
            "method": "DELETE",
            "path": "/v1/subnets/{subnet_id}",
            "service": "vpc"
          },
          "adopt": "subnet"
        },
        {
          "name": "wait-subnet",
          "service": "vpc",
          "method": "GET",
          "path": "/v1/subnets/{subnet_id}",
          "expect_status": [200],
          "poll": {
            "field": "$.subnet.state",
            "until": ["ACTIVE"],
            "timeout": 180,
            "interval": 10
          }
        },
        {
          "name": "create-privatelink-service",
          "service": "vpc",
          "method": "POST",
          "path": "/v1/privatelink-services",
          "_note": "UNPROVEN — first live exercise of PrivateLinkServiceCreateRequest. approval_type AUTO so downstream endpoint requests self-approve; connected_resource_type IP with two free IPs inside the subnet /24 (no LB/VM needed). 202 PrivateLinkServiceShowResponse.",
          "json": {
            "name": "regrpls{ualpha}",
            "description": "API regression wave5 privatelink service",
            "approval_type": "AUTO",
            "connected_resource_type": "IP",
            "connected_resource_ip_address": "10.163.8.10",
            "service_ip_address": "10.163.8.5",
            "subnet_id": "{subnet_id}",
            "tags": []
          },
          "expect_status": [200, 201, 202],
          "capture": {
            "pls_id": "$.privatelink_service.id"
          },
          "cleanup": {
            "method": "DELETE",
            "path": "/v1/privatelink-services/{pls_id}",
            "service": "vpc"
          }
        },
        {
          "name": "wait-privatelink-service",
          "service": "vpc",
          "method": "GET",
          "path": "/v1/privatelink-services/{pls_id}",
          "expect_status": [200],
          "poll": {
            "field": "$.privatelink_service.state",
            "until": ["ACTIVE"],
            "timeout": 300,
            "interval": 10
          }
        },
        {
          "name": "create-api",
          "service": "apigateway",
          "method": "POST",
          "path": "/v1/apis",
          "_note": "own api for the {api_id} the connection/approval DTOs require (PrivateLinkEndpointConnectionRequest/ApprovalRequest both carry api_id).",
          "json": {
            "name": "regrw5ple{ualpha}",
            "description": "API regression wave5 privatelink",
            "endpoint_type": "REGION",
            "tags": []
          },
          "expect_status": [200, 201, 202],
          "capture": {
            "api_id": "$.id"
          },
          "cleanup": {
            "method": "DELETE",
            "path": "/v1/apis/{api_id}",
            "service": "apigateway"
          }
        },
        {
          "name": "create-apigw-privatelink-endpoint",
          "service": "apigateway",
          "method": "POST",
          "path": "/v1/privatelink-endpoints",
          "_note": "PrivateLinkEndpointCreateRequest verbatim: name (alnum 3-20, NO hyphens), privatelink_service_id, description? — wired to the real AUTO-approval service created above. capture envelope $.privatelink_endpoint.id is docs-derived (UNPROVEN).",
          "json": {
            "name": "regrple{ualpha}",
            "privatelink_service_id": "{pls_id}",
            "description": "API regression wave5 privatelink endpoint"
          },
          "expect_status": [200, 201, 202],
          "capture": {
            "ple_id": "$.privatelink_endpoint.id"
