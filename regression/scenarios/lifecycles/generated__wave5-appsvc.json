            "method": "DELETE",
            "path": "/v1/privatelink-endpoints/{ple_id}",
            "service": "apigateway"
          }
        },
        {
          "name": "show-apigw-privatelink-endpoint",
          "service": "apigateway",
          "method": "GET",
          "path": "/v1/privatelink-endpoints/{ple_id}",
          "expect_status": [200],
          "group": "apigw-ple"
        },
        {
          "name": "set-apigw-privatelink-endpoint",
          "service": "apigateway",
          "method": "PUT",
          "path": "/v1/privatelink-endpoints/{ple_id}",
          "_note": "setprivatelinkendpoint — PrivateLinkEndpointSetRequest is description-only metadata, state-machine-free, so a strict 2xx is expected.",
          "json": {
            "description": "API regression wave5 privatelink endpoint (updated)"
          },
          "expect_status": [200, 202],
          "group": "apigw-ple"
        },
        {
          "name": "approve-apigw-privatelink-endpoint",
          "service": "apigateway",
          "method": "PUT",
          "path": "/v1/privatelink-endpoints/{ple_id}/approval",
          "_note": "GATED PROBE — PrivateLinkEndpointApprovalRequest {api_id, type APPROVE|REJECT}. With approval_type AUTO the endpoint may already be approved -> 4xx tolerated; the op still records. If live shows MANUAL flow is needed, flip the privatelink-service to MANUAL and approve here.",
          "json": {
            "api_id": "{api_id}",
            "type": "APPROVE"
          },
          "expect_status": [200, 202, 400, 403, 404, 409, 422],
          "optional": true,
          "group": "apigw-ple-actions"
        },
        {
          "name": "connect-apigw-privatelink-endpoint-disconnect",
          "service": "apigateway",
          "method": "PUT",
          "path": "/v1/privatelink-endpoints/{ple_id}/connection",
          "_note": "GATED PROBE — PrivateLinkEndpointConnectionRequest {api_id, type DISCONNECT|RECONNECT}. DISCONNECT first (2xx if the AUTO flow auto-connected), RECONNECT next — paired probes so one of the two lands 2xx whichever state the endpoint is in.",
          "json": {
            "api_id": "{api_id}",
            "type": "DISCONNECT"
          },
          "expect_status": [200, 202, 400, 403, 404, 409, 422],
          "optional": true,
          "group": "apigw-ple-actions"
        },
        {
          "name": "connect-apigw-privatelink-endpoint-reconnect",
          "service": "apigateway",
          "method": "PUT",
          "path": "/v1/privatelink-endpoints/{ple_id}/connection",
          "json": {
            "api_id": "{api_id}",
            "type": "RECONNECT"
          },
          "expect_status": [200, 202, 400, 403, 404, 409, 422],
          "optional": true,
          "group": "apigw-ple-actions"
        },
        {
          "name": "request-apigw-privatelink-endpoint",
          "service": "apigateway",
          "method": "PUT",
          "path": "/v1/privatelink-endpoints/{ple_id}/request",
          "_note": "GATED PROBE — PrivateLinkEndpointRequestRequest {type CANCEL|RE_REQUEST}. RE_REQUEST here; CANCEL deliberately last (below) right before delete so a successful cancel can't poison the earlier action probes.",
          "json": {
            "type": "RE_REQUEST"
          },
          "expect_status": [200, 202, 400, 403, 404, 409, 422],
          "optional": true,
          "group": "apigw-ple-actions"
        },
        {
          "name": "cancel-apigw-privatelink-endpoint-request",
          "service": "apigateway",
          "method": "PUT",
          "path": "/v1/privatelink-endpoints/{ple_id}/request",
          "json": {
            "type": "CANCEL"
          },
          "expect_status": [200, 202, 400, 403, 404, 409, 422],
          "optional": true,
          "group": "apigw-ple-actions"
        },
        {
          "name": "delete-apigw-privatelink-endpoint",
          "service": "apigateway",
          "method": "DELETE",
          "path": "/v1/privatelink-endpoints/{ple_id}",
          "expect_status": [200, 202, 204],
