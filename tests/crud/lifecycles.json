{
  "_comment": "Declarative CRUD lifecycles. Steps run in order: create -> read -> [update] -> delete. {placeholders} are filled from earlier 'capture' values plus {unique} (collision-free token) and {region}. Mutating steps need SCP_ALLOW_MUTATIONS=true; steps marked destructive also need SCP_ALLOW_DESTRUCTIVE=true. A step may declare \"wait\": <s> (sleep before it) or \"poll\": {field, until, timeout, interval} to wait for async provisioning. Enable a lifecycle with \"enabled\": true.",
  "lifecycles": [
    {
      "id": "resourcemanager-resource-group",
      "service": "management/resourcemanager",
      "enabled": false,
      "steps": [
        {
          "name": "create",
          "method": "POST",
          "path": "/v1/resource-groups",
          "json": {
            "name": "regr-rg-{unique}",
            "description": "created by API regression suite"
          },
          "expect_status": [
            200,
            201,
            202
          ],
          "capture": {
            "rg_id": "$.resource_group.id"
          }
        },
        {
          "name": "get",
          "method": "GET",
          "path": "/v1/resource-groups/{rg_id}",
          "expect_status": [
            200
          ]
        },
        {
          "name": "list",
          "method": "GET",
          "path": "/v1/resource-groups",
          "expect_status": [
            200
          ]
        },
        {
          "name": "delete",
          "method": "DELETE",
          "path": "/v1/resource-groups/{rg_id}",
          "expect_status": [
            200,
            202,
            204
          ],
          "destructive": true
        }
      ]
    },
    {
      "id": "networking-vpc-subnet",
      "service": "networking/vpc",
      "enabled": false,
      "steps": [
        {
          "name": "create-vpc",
          "method": "POST",
          "path": "/v1/vpcs",
          "json": {
            "name": "regrvpc{unique}",
            "description": "API regression suite",
            "cidr": "10.123.0.0/20",
            "tags": []
          },
          "expect_status": [
            200,
            201,
            202
          ],
          "capture": {
            "vpc_id": "$.vpc.id"
          },
          "cleanup": {
            "method": "DELETE",
            "path": "/v1/vpcs/{vpc_id}",
            "service": "vpc"
          }
        },
        {
          "name": "get-vpc-active",
          "method": "GET",
          "path": "/v1/vpcs/{vpc_id}",
          "expect_status": [
            200
          ],
          "poll": {
            "field": "$.vpc.state",
            "until": [
              "ACTIVE"
            ],
            "timeout": 180,
            "interval": 10
          }
        },
        {
          "name": "list-vpcs",
          "method": "GET",
          "path": "/v1/vpcs",
          "expect_status": [
            200
          ]
        },
        {
          "name": "create-subnet",
          "method": "POST",
          "path": "/v1/subnets",
          "json": {
            "name": "regrsub{unique}",
            "description": "API regression suite",
            "cidr": "10.123.1.0/24",
            "type": "GENERAL",
            "vpc_id": "{vpc_id}",
            "tags": []
          },
          "expect_status": [
            200,
            201,
            202
          ],
          "capture": {
            "subnet_id": "$.subnet.id"
          },
          "cleanup": {
            "method": "DELETE",
            "path": "/v1/subnets/{subnet_id}",
            "service": "vpc"
          }
        },
        {
          "name": "get-subnet-active",
          "method": "GET",
          "path": "/v1/subnets/{subnet_id}",
          "expect_status": [
            200
          ],
          "poll": {
            "field": "$.subnet.state",
            "until": [
              "ACTIVE"
            ],
            "timeout": 180,
            "interval": 10
          }
        },
        {
          "name": "delete-subnet",
          "method": "DELETE",
          "path": "/v1/subnets/{subnet_id}",
          "expect_status": [
            200,
            202,
            204
          ],
          "destructive": true
        },
        {
          "name": "wait-subnet-gone",
          "method": "GET",
          "path": "/v1/subnets/{subnet_id}",
          "expect_status": [
            200,
            404
          ],
          "poll": {
            "until_status": [
              404
            ],
            "timeout": 180,
            "interval": 10
          },
          "service": "vpc"
        },
        {
          "name": "delete-vpc",
          "method": "DELETE",
          "path": "/v1/vpcs/{vpc_id}",
          "expect_status": [
            200,
            202,
            204
          ],
          "destructive": true
        }
      ]
    },
    {
      "id": "container-scr-registry",
      "service": "container/scr",
      "enabled": false,
      "steps": [
        {
          "name": "create",
          "method": "POST",
          "path": "/v1/container-registries",
          "json": {
            "name": "regrscr{unique}",
            "private_acl_enabled": false,
            "private_acl_resources": [],
            "public_acl_resources": [],
            "public_visible_enabled": false
          },
          "expect_status": [
            200,
            201,
            202
          ],
          "capture": {
            "reg_id": "$.id"
          },
          "cleanup": {
            "method": "DELETE",
            "path": "/v1/container-registries/{reg_id}",
            "service": "scr"
          }
        },
        {
          "name": "wait-running",
          "method": "GET",
          "path": "/v1/container-registries/{reg_id}",
          "expect_status": [
            200
          ],
          "poll": {
            "field": "$.state",
            "until": [
              "Running",
              "RUNNING",
              "active",
              "ACTIVE"
            ],
            "timeout": 180,
            "interval": 10
          }
        },
        {
          "name": "list",
          "method": "GET",
          "path": "/v1/container-registries",
          "expect_status": [
            200
          ]
        },
        {
          "name": "delete",
          "method": "DELETE",
          "path": "/v1/container-registries/{reg_id}",
          "expect_status": [
            200,
            202,
            204
          ],
          "destructive": true,
          "retry_on_status": [
            500
          ],
          "retries": 12,
          "retry_interval": 30
        },
        {
          "name": "wait-gone",
          "method": "GET",
          "path": "/v1/container-registries/{reg_id}",
          "expect_status": [
            200,
            404
          ],
          "poll": {
            "until_status": [
              404
            ],
            "timeout": 180,
            "interval": 10
          }
        }
      ],
      "_note": "Registry DELETE returns 500 for a few minutes right after creation (provisioning race), then succeeds; the delete step retries 500 up to ~6 min. Enabled."
    },
    {
      "id": "filestorage-volume",
      "service": "storage/filestorage",
      "enabled": false,
      "steps": [
        {
          "name": "create",
          "method": "POST",
          "path": "/v1/volumes",
          "json": {
            "name": "regrfs{unique}",
            "protocol": "NFS",
            "type_name": "HDD"
          },
          "expect_status": [
            200,
            201,
            202
          ],
          "capture": {
            "volume_id": "$.volume_id"
          },
          "cleanup": {
            "method": "DELETE",
            "path": "/v1/volumes/{volume_id}",
            "service": "filestorage"
          }
        },
        {
          "name": "wait-available",
          "method": "GET",
          "path": "/v1/volumes/{volume_id}",
          "expect_status": [
            200
          ],
          "poll": {
            "field": "$.state",
            "until": [
              "available",
              "AVAILABLE",
              "ACTIVE"
            ],
            "timeout": 300,
            "interval": 15
          }
        },
        {
          "name": "list",
          "method": "GET",
          "path": "/v1/volumes",
          "expect_status": [
            200
          ]
        },
        {
          "name": "delete",
          "method": "DELETE",
          "path": "/v1/volumes/{volume_id}",
          "expect_status": [
            200,
            202,
            204
          ],
          "destructive": true
        },
        {
          "name": "wait-gone",
          "method": "GET",
          "path": "/v1/volumes/{volume_id}",
          "expect_status": [
            200,
            404
          ],
          "poll": {
            "until_status": [
              404
            ],
            "timeout": 300,
            "interval": 15
          }
        }
      ]
    },
    {
      "id": "container-ske-cluster-nodepool",
      "service": "container/ske",
      "enabled": true,
      "_note": "Full K8s stack: vpc->subnet->sg->keypair->discover k8s version & server type->create cluster->poll RUNNING (slow, ~20min)->create nodepool->poll Running (boots node VMs)->delete nodepool->delete cluster->teardown. SLOW (~40-60min) and BILLABLE (control plane + node VMs). First runs may need field tuning (k8s version currency, volume fields, image_os).",
      "steps": [
        {
          "name": "create-vpc",
          "service": "vpc",
          "method": "POST",
          "path": "/v1/vpcs",
          "json": {
            "name": "regrvpc{unique}",
            "description": "API regression SKE",
            "cidr": "10.125.0.0/20",
            "tags": []
          },
          "expect_status": [
            200,
            201,
            202
          ],
          "capture": {
            "vpc_id": "$.vpc.id"
          },
          "cleanup": {
            "method": "DELETE",
            "path": "/v1/vpcs/{vpc_id}",
            "service": "vpc"
          }
        },
        {
          "name": "wait-vpc",
          "service": "vpc",
          "method": "GET",
          "path": "/v1/vpcs/{vpc_id}",
          "expect_status": [
            200
          ],
          "poll": {
            "field": "$.vpc.state",
            "until": [
              "ACTIVE"
            ],
            "timeout": 180,
            "interval": 10
          }
        },
        {
          "name": "create-subnet",
          "service": "vpc",
          "method": "POST",
          "path": "/v1/subnets",
          "json": {
            "name": "regrsub{unique}",
            "description": "API regression SKE",
            "cidr": "10.125.1.0/24",
            "type": "GENERAL",
            "vpc_id": "{vpc_id}",
            "tags": []
          },
          "expect_status": [
            200,
            201,
            202
          ],
          "capture": {
            "subnet_id": "$.subnet.id"
          },
          "cleanup": {
            "method": "DELETE",
            "path": "/v1/subnets/{subnet_id}",
            "service": "vpc"
          }
        },
        {
          "name": "wait-subnet",
          "service": "vpc",
          "method": "GET",
          "path": "/v1/subnets/{subnet_id}",
          "expect_status": [
            200
          ],
          "poll": {
            "field": "$.subnet.state",
            "until": [
              "ACTIVE"
            ],
            "timeout": 180,
            "interval": 10
          }
        },
        {
          "name": "create-sg",
          "service": "security-group",
          "method": "POST",
          "path": "/v1/security-groups",
          "json": {
            "name": "regrsg{unique}",
            "description": "API regression SKE",
            "loggable": false,
            "tags": []
          },
          "expect_status": [
            200,
            201,
            202
          ],
          "capture": {
            "sg_id": "$.security_group.id"
          },
          "cleanup": {
            "method": "DELETE",
            "path": "/v1/security-groups/{sg_id}",
            "service": "security-group"
          }
        },
        {
          "name": "create-keypair",
          "service": "virtualserver",
          "method": "POST",
          "path": "/v1/keypairs",
          "json": {
            "name": "regrkey{unique}",
            "tags": []
          },
          "expect_status": [
            200,
            201,
            202
          ],
          "cleanup": {
            "method": "DELETE",
            "path": "/v1/keypairs/regrkey{unique}",
            "service": "virtualserver"
          }
        },
        {
          "name": "find-k8s-version",
          "service": "ske",
          "method": "GET",
          "path": "/v1/kubernetes-versions",
          "expect_status": [
            200
          ],
          "capture": {
            "kube_ver": "$.kubernetes_versions[0].kubernetes_version"
          }
        },
        {
          "name": "find-server-type",
          "service": "virtualserver",
          "method": "GET",
          "path": "/v1/server-types",
          "expect_status": [
            200
          ],
          "capture": {
            "server_type_id": {
              "list": "$.server_types",
              "where_prefix": {
                "id": "s"
              },
              "where_not_prefix": {
                "id": "g"
              },
              "get": "id"
            }
          }
        },
        {
          "name": "create-vol",
          "service": "filestorage",
          "method": "POST",
          "path": "/v1/volumes",
          "json": {
            "name": "regrfsk{unique}",
            "protocol": "NFS",
            "type_name": "HDD"
          },
          "expect_status": [
            200,
            201,
            202
          ],
          "capture": {
            "ske_vol_id": "$.volume_id"
          },
          "cleanup": {
            "method": "DELETE",
            "path": "/v1/volumes/{ske_vol_id}",
            "service": "filestorage"
          }
        },
        {
          "name": "wait-vol",
          "service": "filestorage",
          "method": "GET",
          "path": "/v1/volumes/{ske_vol_id}",
          "expect_status": [
            200
          ],
          "poll": {
            "field": "$.state",
            "until": [
              "available",
              "AVAILABLE",
              "ACTIVE"
            ],
            "timeout": 300,
            "interval": 15
          }
        },
        {
          "name": "create-cluster",
          "service": "ske",
          "method": "POST",
          "path": "/v1/clusters",
          "json": {
            "name": "regrske{unique}",
            "kubernetes_version": "{kube_ver}",
            "cloud_logging_enabled": "false",
            "vpc_id": "{vpc_id}",
            "subnet_id": "{subnet_id}",
            "security_group_id_list": [
              "{sg_id}"
            ],
            "private_endpoint_access_control_resources": [],
            "tags": [],
            "volume_id": [
              "{ske_vol_id}"
            ],
            "public_endpoint_access_control_ip": "0.0.0.0/0"
          },
          "expect_status": [
            200,
            201,
            202
          ],
          "capture": {
            "cluster_id": "$.resource_id"
          },
          "cleanup": {
            "method": "DELETE",
            "path": "/v1/clusters/{cluster_id}",
            "service": "ske"
          }
        },
        {
          "name": "wait-cluster",
          "service": "ske",
          "method": "GET",
          "path": "/v1/clusters/{cluster_id}",
          "expect_status": [
            200
          ],
          "poll": {
            "field": "$.cluster.status",
            "until": [
              "RUNNING",
              "ACTIVE",
              "Running"
            ],
            "timeout": 1800,
            "interval": 30
          }
        },
        {
          "name": "create-nodepool",
          "service": "ske",
          "method": "POST",
          "path": "/v1/nodepools",
          "json": {
            "cluster_id": "{cluster_id}",
            "name": "regrnp{unique}",
            "kubernetes_version": "{kube_ver}",
            "desired_node_count": "1",
            "min_node_count": "1",
            "max_node_count": "2",
            "server_type_id": "{server_type_id}",
            "image_os": "ubuntu",
            "image_os_version": "22.04",
            "keypair_name": "regrkey{unique}",
            "volume_size": "104",
            "volume_type_name": "SSD_Provisioned",
            "is_auto_recovery": "true",
            "is_auto_scale": "false"
          },
          "expect_status": [
            200,
            201,
            202
          ],
          "capture": {
            "nodepool_id": "$.nodepool.id"
          },
          "cleanup": {
            "method": "DELETE",
            "path": "/v1/nodepools/{nodepool_id}",
            "service": "ske"
          }
        },
        {
          "name": "wait-nodepool",
          "service": "ske",
          "method": "GET",
          "path": "/v1/nodepools/{nodepool_id}",
          "expect_status": [
            200
          ],
          "poll": {
            "field": "$.nodepool.status",
            "until": [
              "Running",
              "RUNNING",
              "ACTIVE",
              "active"
            ],
            "timeout": 1200,
            "interval": 30
          }
        },
        {
          "name": "list-nodepools",
          "service": "ske",
          "method": "GET",
          "path": "/v1/clusters/{cluster_id}/nodepools",
          "expect_status": [
            200
          ]
        },
        {
          "name": "delete-nodepool",
          "service": "ske",
          "method": "DELETE",
          "path": "/v1/nodepools/{nodepool_id}",
          "expect_status": [
            200,
            202,
            204
          ],
          "destructive": true,
          "retry_on_status": [
            409,
            500
          ],
          "retries": 6,
          "retry_interval": 30
        },
        {
          "name": "wait-nodepool-gone",
          "service": "ske",
          "method": "GET",
          "path": "/v1/nodepools/{nodepool_id}",
          "expect_status": [
            200,
            404
          ],
          "poll": {
            "until_status": [
              404
            ],
            "timeout": 900,
            "interval": 30
          }
        },
        {
          "name": "delete-cluster",
          "service": "ske",
          "method": "DELETE",
          "path": "/v1/clusters/{cluster_id}",
          "expect_status": [
            200,
            202,
            204
          ],
          "destructive": true,
          "retry_on_status": [
            409,
            500
          ],
          "retries": 8,
          "retry_interval": 30
        },
        {
          "name": "wait-cluster-gone",
          "service": "ske",
          "method": "GET",
          "path": "/v1/clusters/{cluster_id}",
          "expect_status": [
            200,
            404
          ],
          "poll": {
            "until_status": [
              404
            ],
            "timeout": 1200,
            "interval": 30
          }
        },
        {
          "name": "delete-vol",
          "service": "filestorage",
          "method": "DELETE",
          "path": "/v1/volumes/{ske_vol_id}",
          "expect_status": [
            200,
            202,
            204
          ],
          "destructive": true
        },
        {
          "name": "delete-keypair",
          "service": "virtualserver",
          "method": "DELETE",
          "path": "/v1/keypairs/regrkey{unique}",
          "expect_status": [
            200,
            202,
            204
          ],
          "destructive": true
        },
        {
          "name": "delete-sg",
          "service": "security-group",
          "method": "DELETE",
          "path": "/v1/security-groups/{sg_id}",
          "expect_status": [
            200,
            202,
            204
          ],
          "destructive": true
        },
        {
          "name": "delete-subnet",
          "service": "vpc",
          "method": "DELETE",
          "path": "/v1/subnets/{subnet_id}",
          "expect_status": [
            200,
            202,
            204
          ],
          "destructive": true
        },
        {
          "name": "wait-subnet-gone",
          "service": "vpc",
          "method": "GET",
          "path": "/v1/subnets/{subnet_id}",
          "expect_status": [
            200,
            404
          ],
          "poll": {
            "until_status": [
              404
            ],
            "timeout": 300,
            "interval": 15
          }
        },
        {
          "name": "delete-vpc",
          "service": "vpc",
          "method": "DELETE",
          "path": "/v1/vpcs/{vpc_id}",
          "expect_status": [
            200,
            202,
            204
          ],
          "destructive": true
        }
      ]
    },
