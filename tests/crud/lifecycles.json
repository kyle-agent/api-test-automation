{
  "_comment": "Declarative CRUD lifecycles. Steps run in order: create -> read -> [update] -> delete. {placeholders} are filled from earlier 'capture' values plus {unique} (collision-free token) and {region}. Mutating steps need SCP_ALLOW_MUTATIONS=true; steps marked destructive also need SCP_ALLOW_DESTRUCTIVE=true. A step may declare \"wait\": <s> (sleep before it) or \"poll\": {field, until, timeout, interval} to wait for async provisioning. Enable a lifecycle with \"enabled\": true.",
  "lifecycles": [
    {
      "id": "resourcemanager-resource-group",
      "service": "management/resourcemanager",
      "enabled": true,
      "steps": [
        {
          "name": "create",
          "method": "POST",
          "path": "/v1/resource-groups",
          "json": {
            "name": "regr-rg-{unique}",
            "description": "created by API regression suite"
          },
          "expect_status": [
            200,
            201,
            202
          ],
          "capture": {
            "rg_id": "$.resource_group.id"
          }
        },
        {
          "name": "get",
          "method": "GET",
          "path": "/v1/resource-groups/{rg_id}",
          "expect_status": [
            200
          ]
        },
        {
          "name": "list",
          "method": "GET",
          "path": "/v1/resource-groups",
          "expect_status": [
            200
          ]
        },
        {
          "name": "delete",
          "method": "DELETE",
          "path": "/v1/resource-groups/{rg_id}",
          "expect_status": [
            200,
            202,
            204
          ],
          "destructive": true
        }
      ]
    },
    {
      "id": "networking-vpc-subnet",
      "service": "networking/vpc",
      "enabled": true,
      "steps": [
        {
          "name": "create-vpc",
          "method": "POST",
          "path": "/v1/vpcs",
          "json": {
            "name": "regrvpc{unique}",
            "description": "API regression suite",
            "cidr": "10.123.0.0/20",
            "tags": []
          },
          "expect_status": [
            200,
            201,
            202
          ],
          "capture": {
            "vpc_id": "$.vpc.id"
          },
          "cleanup": {
            "method": "DELETE",
            "path": "/v1/vpcs/{vpc_id}",
            "service": "vpc"
          }
        },
        {
          "name": "get-vpc-active",
          "method": "GET",
          "path": "/v1/vpcs/{vpc_id}",
          "expect_status": [
            200
          ],
          "poll": {
            "field": "$.vpc.state",
            "until": [
              "ACTIVE"
            ],
            "timeout": 180,
            "interval": 10
          }
        },
        {
          "name": "list-vpcs",
          "method": "GET",
          "path": "/v1/vpcs",
          "expect_status": [
            200
          ]
        },
        {
          "name": "create-subnet",
          "method": "POST",
          "path": "/v1/subnets",
          "json": {
            "name": "regrsub{unique}",
            "description": "API regression suite",
            "cidr": "10.123.1.0/24",
            "type": "GENERAL",
            "vpc_id": "{vpc_id}",
            "tags": []
          },
          "expect_status": [
            200,
            201,
            202
          ],
          "capture": {
            "subnet_id": "$.subnet.id"
          },
          "cleanup": {
            "method": "DELETE",
            "path": "/v1/subnets/{subnet_id}",
            "service": "vpc"
          }
        },
        {
          "name": "get-subnet-active",
          "method": "GET",
          "path": "/v1/subnets/{subnet_id}",
          "expect_status": [
            200
          ],
          "poll": {
            "field": "$.subnet.state",
            "until": [
              "ACTIVE"
            ],
            "timeout": 180,
            "interval": 10
          }
        },
        {
          "name": "delete-subnet",
          "method": "DELETE",
          "path": "/v1/subnets/{subnet_id}",
          "expect_status": [
            200,
            202,
            204
          ],
          "destructive": true
        },
        {
          "name": "wait-subnet-gone",
          "method": "GET",
          "path": "/v1/subnets/{subnet_id}",
          "expect_status": [
            200,
            404
          ],
          "poll": {
            "until_status": [
              404
            ],
            "timeout": 180,
            "interval": 10
          },
          "service": "vpc"
        },
        {
          "name": "delete-vpc",
          "method": "DELETE",
          "path": "/v1/vpcs/{vpc_id}",
          "expect_status": [
            200,
            202,
            204
          ],
          "destructive": true
        }
      ]
    },
    {
      "id": "container-scr-registry",
      "service": "container/scr",
      "enabled": false,
      "steps": [
        {
          "name": "create",
          "method": "POST",
          "path": "/v1/container-registries",
          "json": {
            "name": "regrscr{unique}",
            "private_acl_enabled": false,
            "private_acl_resources": [],
            "public_acl_resources": [],
            "public_visible_enabled": false
          },
          "expect_status": [
            200,
            201,
            202
          ],
          "capture": {
            "reg_id": "$.id"
          },
          "cleanup": {
            "method": "DELETE",
            "path": "/v1/container-registries/{reg_id}",
            "service": "scr"
          }
        },
        {
          "name": "wait-running",
          "method": "GET",
          "path": "/v1/container-registries/{reg_id}",
          "expect_status": [
            200
          ],
          "poll": {
            "field": "$.state",
            "until": [
              "Running",
              "RUNNING",
              "active",
              "ACTIVE"
            ],
            "timeout": 180,
            "interval": 10
          }
        },
        {
          "name": "list",
          "method": "GET",
          "path": "/v1/container-registries",
          "expect_status": [
            200
          ]
        },
        {
          "name": "delete",
          "method": "DELETE",
          "path": "/v1/container-registries/{reg_id}",
          "expect_status": [
            200,
            202,
            204
          ],
          "destructive": true,
          "retry_on_status": [
            500
          ],
          "retries": 4,
          "retry_interval": 20
        },
        {
          "name": "wait-gone",
          "method": "GET",
          "path": "/v1/container-registries/{reg_id}",
          "expect_status": [
            200,
            404
          ],
          "poll": {
            "until_status": [
              404
            ],
            "timeout": 180,
            "interval": 10
          }
        }
      ],
      "_note": "Registry CREATE/READ/LIST work, but DELETE returns a persistent 500 (ContactAdminForAssistance) on SCP's side, so each run would leak a registry. Disabled pending decision. Leaked registries need manual console deletion."
    },
    {
      "id": "filestorage-volume",
      "service": "storage/filestorage",
      "enabled": true,
      "steps": [
        {
          "name": "create",
          "method": "POST",
          "path": "/v1/volumes",
          "json": {
            "name": "regrfs{unique}",
            "protocol": "NFS",
            "type_name": "HDD"
          },
          "expect_status": [
            200,
            201,
            202
          ],
          "capture": {
            "volume_id": "$.volume_id"
          },
          "cleanup": {
            "method": "DELETE",
            "path": "/v1/volumes/{volume_id}",
            "service": "filestorage"
          }
        },
        {
          "name": "wait-available",
          "method": "GET",
          "path": "/v1/volumes/{volume_id}",
          "expect_status": [
            200
          ],
          "poll": {
            "field": "$.state",
            "until": [
              "available",
              "AVAILABLE",
              "ACTIVE"
            ],
            "timeout": 300,
            "interval": 15
          }
        },
        {
          "name": "list",
          "method": "GET",
          "path": "/v1/volumes",
          "expect_status": [
            200
          ]
        },
        {
          "name": "delete",
          "method": "DELETE",
          "path": "/v1/volumes/{volume_id}",
          "expect_status": [
            200,
            202,
            204
          ],
          "destructive": true
        },
        {
          "name": "wait-gone",
          "method": "GET",
          "path": "/v1/volumes/{volume_id}",
          "expect_status": [
            200,
            404
          ],
          "poll": {
            "until_status": [
              404
            ],
            "timeout": 300,
            "interval": 15
          }
        }
      ]
    },
    {
      "id": "compute-virtualserver-full",
      "service": "virtualserver",
      "enabled": true,
      "_note": "VALIDATED end-to-end (creates a real, billable VM ~17min and tears it down). Enabled per request; disable (enabled=false) to avoid recurring VM cost on routine runs.",
      "steps": [
        {
          "name": "create-vpc",
          "service": "vpc",
          "method": "POST",
          "path": "/v1/vpcs",
          "json": {
            "name": "regrvpc{unique}",
            "description": "API regression VS",
            "cidr": "10.124.0.0/20",
            "tags": []
          },
          "expect_status": [
            200,
            201,
            202
          ],
          "capture": {
            "vpc_id": "$.vpc.id"
          },
          "cleanup": {
            "method": "DELETE",
            "path": "/v1/vpcs/{vpc_id}",
            "service": "vpc"
          }
        },
        {
          "name": "wait-vpc",
          "service": "vpc",
          "method": "GET",
          "path": "/v1/vpcs/{vpc_id}",
          "expect_status": [
            200
          ],
          "poll": {
            "field": "$.vpc.state",
            "until": [
              "ACTIVE"
            ],
            "timeout": 180,
            "interval": 10
          }
        },
        {
          "name": "create-subnet",
          "service": "vpc",
          "method": "POST",
          "path": "/v1/subnets",
          "json": {
            "name": "regrsub{unique}",
            "description": "API regression VS",
            "cidr": "10.124.1.0/24",
            "type": "GENERAL",
            "vpc_id": "{vpc_id}",
            "tags": []
          },
          "expect_status": [
            200,
            201,
            202
          ],
          "capture": {
            "subnet_id": "$.subnet.id"
          },
          "cleanup": {
            "method": "DELETE",
            "path": "/v1/subnets/{subnet_id}",
            "service": "vpc"
          }
        },
        {
          "name": "wait-subnet",
          "service": "vpc",
          "method": "GET",
          "path": "/v1/subnets/{subnet_id}",
          "expect_status": [
            200
          ],
          "poll": {
            "field": "$.subnet.state",
            "until": [
              "ACTIVE"
            ],
            "timeout": 180,
            "interval": 10
          }
        },
        {
          "name": "create-sg",
          "service": "security-group",
          "method": "POST",
          "path": "/v1/security-groups",
          "json": {
            "name": "regrsg{unique}",
            "description": "API regression VS",
            "loggable": false,
            "tags": []
          },
          "expect_status": [
            200,
            201,
            202
          ],
          "capture": {
            "sg_id": "$.security_group.id"
          },
          "cleanup": {
            "method": "DELETE",
            "path": "/v1/security-groups/{sg_id}",
            "service": "security-group"
          }
        },
        {
          "name": "create-keypair",
          "method": "POST",
          "path": "/v1/keypairs",
          "json": {
            "name": "regrkey{unique}",
            "tags": []
          },
          "expect_status": [
            200,
            201,
            202
          ],
          "cleanup": {
            "method": "DELETE",
            "path": "/v1/keypairs/regrkey{unique}",
            "service": "virtualserver"
          }
        },
        {
          "name": "find-image",
          "method": "GET",
          "path": "/v1/images",
          "expect_status": [
            200
          ],
          "capture": {
            "image_id": "$.images[0].id"
          },
          "params": {
            "status": "active",
            "scp_original_image_type": "standard",
            "visibility": "public",
            "limit": 50
          }
        },
        {
          "name": "find-server-type",
          "method": "GET",
          "path": "/v1/server-types",
          "expect_status": [
            200
          ],
          "capture": {
            "server_type_id": {
              "list": "$.server_types",
              "where_prefix": {
                "id": "s"
              },
              "where_not_prefix": {
                "id": "g"
              },
              "get": "id"
            }
          }
        },
        {
          "name": "create-server",
          "method": "POST",
          "path": "/v1/servers",
          "json": {
            "name": "regrsrv{unique}",
            "image_id": "{image_id}",
            "server_type_id": "{server_type_id}",
            "keypair_name": "regrkey{unique}",
            "product_category": "compute",
            "product_offering": "virtual_server",
            "networks": [
              {
                "subnet_id": "{subnet_id}"
              }
            ],
            "security_groups": [
              "{sg_id}"
            ],
            "volumes": [
              {
                "boot_index": 0,
                "size": 104,
                "type": "SSD",
                "delete_on_termination": true
              }
            ]
          },
          "expect_status": [
            200,
            201,
            202
          ],
          "capture": {
            "server_id": "$.servers[0].id"
          },
          "cleanup": {
            "method": "DELETE",
            "path": "/v1/servers/{server_id}",
            "service": "virtualserver"
          }
        },
        {
          "name": "wait-server-active",
          "method": "GET",
          "path": "/v1/servers/{server_id}",
          "expect_status": [
            200
          ],
          "poll": {
            "field": "$.server.state",
            "until": [
              "ACTIVE"
            ],
            "timeout": 600,
            "interval": 15
          }
        },
        {
          "name": "delete-server",
          "method": "DELETE",
          "path": "/v1/servers/{server_id}",
          "expect_status": [
            200,
            202,
            204
          ],
          "destructive": true
        },
        {
          "name": "wait-server-gone",
          "method": "GET",
          "path": "/v1/servers/{server_id}",
          "expect_status": [
            200,
            404
          ],
          "poll": {
            "until_status": [
              404
            ],
            "timeout": 600,
            "interval": 15
          }
        },
        {
          "name": "delete-keypair",
          "method": "DELETE",
          "path": "/v1/keypairs/regrkey{unique}",
          "expect_status": [
            200,
            202,
            204
          ],
          "destructive": true
        },
        {
          "name": "delete-sg",
          "service": "security-group",
          "method": "DELETE",
          "path": "/v1/security-groups/{sg_id}",
          "expect_status": [
            200,
            202,
            204
          ],
          "destructive": true
        },
        {
          "name": "delete-subnet",
          "service": "vpc",
          "method": "DELETE",
          "path": "/v1/subnets/{subnet_id}",
          "expect_status": [
            200,
            202,
            204
          ],
          "destructive": true
        },
        {
          "name": "wait-subnet-gone",
          "method": "GET",
          "path": "/v1/subnets/{subnet_id}",
          "expect_status": [
            200,
            404
          ],
          "poll": {
            "until_status": [
              404
            ],
            "timeout": 180,
            "interval": 10
          },
          "service": "vpc"
        },
        {
          "name": "delete-vpc",
          "service": "vpc",
          "method": "DELETE",
          "path": "/v1/vpcs/{vpc_id}",
          "expect_status": [
            200,
            202,
            204
          ],
          "destructive": true
        }
      ]
    }
  ]
}