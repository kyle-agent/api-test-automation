            "service": "virtualserver"
          }
        },
        {
          "name": "find-image",
          "method": "GET",
          "path": "/v1/images",
          "expect_status": [
            200
          ],
          "capture": {
            "image_id": "$.images[0].id"
          },
          "params": {
            "status": "active",
            "scp_original_image_type": "standard",
            "visibility": "public",
            "limit": 50
          }
        },
        {
          "name": "find-server-type",
          "method": "GET",
          "path": "/v1/server-types",
          "expect_status": [
            200
          ],
          "capture": {
            "server_type_id": {
              "list": "$.server_types",
              "where_prefix": {
                "id": "s"
              },
              "where_not_prefix": {
                "id": "g"
              },
              "get": "id"
            }
          }
        },
        {
          "name": "create-server",
          "method": "POST",
          "path": "/v1/servers",
          "json": {
            "name": "regrsrv{unique}",
            "image_id": "{image_id}",
            "server_type_id": "{server_type_id}",
            "keypair_name": "regrkey{unique}",
            "product_category": "compute",
            "product_offering": "virtual_server",
            "networks": [
              {
                "subnet_id": "{subnet_id}"
              }
            ],
            "security_groups": [
              "{sg_id}"
            ],
            "volumes": [
              {
                "boot_index": 0,
                "size": 104,
                "type": "SSD",
                "delete_on_termination": true
              }
            ]
          },
          "expect_status": [
            200,
            201,
            202
          ],
          "capture": {
            "server_id": "$.servers[0].id"
          },
          "cleanup": {
            "method": "DELETE",
            "path": "/v1/servers/{server_id}",
            "service": "virtualserver"
          }
        },
        {
          "name": "wait-server-active",
          "method": "GET",
          "path": "/v1/servers/{server_id}",
          "expect_status": [
            200
          ],
          "poll": {
            "field": "$.server.state",
            "until": [
              "ACTIVE"
            ],
            "timeout": 600,
            "interval": 15
          }
        },
        {
          "name": "delete-server",
          "method": "DELETE",
          "path": "/v1/servers/{server_id}",
          "expect_status": [
            200,
            202,
            204
          ],
          "destructive": true
        },
        {
          "name": "wait-server-gone",
          "method": "GET",
          "path": "/v1/servers/{server_id}",
          "expect_status": [
            200,
            404
          ],
          "poll": {
            "until_status": [
              404
            ],
            "timeout": 600,
            "interval": 15
          }
        },
        {
          "name": "delete-keypair",
          "method": "DELETE",
          "path": "/v1/keypairs/regrkey{unique}",
          "expect_status": [
            200,
            202,
            204
          ],
          "destructive": true
        },
        {
          "name": "delete-sg",
          "service": "security-group",
          "method": "DELETE",
          "path": "/v1/security-groups/{sg_id}",
          "expect_status": [
            200,
            202,
            204
          ],
          "destructive": true
        },
        {
          "name": "delete-subnet",
          "service": "vpc",
          "method": "DELETE",
          "path": "/v1/subnets/{subnet_id}",
          "expect_status": [
            200,
            202,
            204
          ],
          "destructive": true
        },
        {
          "name": "wait-subnet-gone",
          "method": "GET",
          "path": "/v1/subnets/{subnet_id}",
          "expect_status": [
            200,
            404
          ],
          "poll": {
            "until_status": [
              404
            ],
            "timeout": 180,
            "interval": 10
          },
          "service": "vpc"
        },
        {
          "name": "delete-vpc",
          "service": "vpc",
          "method": "DELETE",
          "path": "/v1/vpcs/{vpc_id}",
          "expect_status": [
            200,
            202,
            204
          ],
          "destructive": true
        }
      ]
    }
  ]
}