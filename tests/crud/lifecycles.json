{
  "_comment": "Declarative CRUD lifecycles. Steps run in order: create -> read -> [update] -> delete. {placeholders} are filled from earlier 'capture' values plus {unique} (collision-free token) and {region}. Mutating steps need SCP_ALLOW_MUTATIONS=true; steps marked destructive also need SCP_ALLOW_DESTRUCTIVE=true. A step may declare \"wait\": <s> (sleep before it) or \"poll\": {field, until, timeout, interval} to wait for async provisioning. Enable a lifecycle with \"enabled\": true.",
  "lifecycles": [
    {
      "id": "resourcemanager-resource-group",
      "service": "management/resourcemanager",
      "enabled": true,
      "steps": [
        {
          "name": "create",
          "method": "POST",
          "path": "/v1/resource-groups",
          "json": {
            "name": "regr-rg-{unique}",
            "description": "created by API regression suite"
          },
          "expect_status": [
            200,
            201,
            202
          ],
          "capture": {
            "rg_id": "$.resource_group.id"
          }
        },
        {
          "name": "get",
          "method": "GET",
          "path": "/v1/resource-groups/{rg_id}",
          "expect_status": [
            200
          ]
        },
        {
          "name": "list",
          "method": "GET",
          "path": "/v1/resource-groups",
          "expect_status": [
            200
          ]
        },
        {
          "name": "delete",
          "method": "DELETE",
          "path": "/v1/resource-groups/{rg_id}",
          "expect_status": [
            200,
            202,
            204
          ],
          "destructive": true
        }
      ]
    },
    {
      "id": "networking-vpc-subnet",
      "service": "networking/vpc",
      "enabled": true,
      "steps": [
        {
          "name": "create-vpc",
          "method": "POST",
          "path": "/v1/vpcs",
          "json": {
            "name": "regrvpc{unique}",
            "description": "API regression suite",
            "cidr": "10.123.0.0/20",
            "tags": []
          },
          "expect_status": [
            200,
            201,
            202
          ],
          "capture": {
            "vpc_id": "$.vpc.id"
          },
          "cleanup": {
            "method": "DELETE",
            "path": "/v1/vpcs/{vpc_id}",
            "service": "vpc"
          }
        },
        {
          "name": "get-vpc-active",
          "method": "GET",
          "path": "/v1/vpcs/{vpc_id}",
          "expect_status": [
            200
          ],
          "poll": {
            "field": "$.vpc.state",
            "until": [
              "ACTIVE"
            ],
            "timeout": 180,
            "interval": 10
          }
        },
        {
          "name": "list-vpcs",
          "method": "GET",
          "path": "/v1/vpcs",
          "expect_status": [
            200
          ]
        },
        {
          "name": "create-subnet",
          "method": "POST",
          "path": "/v1/subnets",
          "json": {
            "name": "regrsub{unique}",
            "description": "API regression suite",
            "cidr": "10.123.1.0/24",
            "type": "GENERAL",
            "vpc_id": "{vpc_id}",
            "tags": []
          },
          "expect_status": [
            200,
            201,
            202
          ],
          "capture": {
            "subnet_id": "$.subnet.id"
          },
          "cleanup": {
            "method": "DELETE",
            "path": "/v1/subnets/{subnet_id}",
            "service": "vpc"
          }
        },
        {
          "name": "get-subnet-active",
          "method": "GET",
          "path": "/v1/subnets/{subnet_id}",
          "expect_status": [
            200
          ],
          "poll": {
            "field": "$.subnet.state",
            "until": [
              "ACTIVE"
            ],
            "timeout": 180,
            "interval": 10
          }
        },
        {
          "name": "delete-subnet",
          "method": "DELETE",
          "path": "/v1/subnets/{subnet_id}",
          "expect_status": [
            200,
            202,
            204
          ],
          "destructive": true
        },
        {
          "name": "wait-subnet-gone",
          "method": "GET",
          "path": "/v1/subnets/{subnet_id}",
          "expect_status": [
            200,
            404
          ],
          "poll": {
            "until_status": [
              404
            ],
            "timeout": 180,
            "interval": 10
          },
          "service": "vpc"
        },
        {
          "name": "delete-vpc",
          "method": "DELETE",
          "path": "/v1/vpcs/{vpc_id}",
          "expect_status": [
            200,
            202,
            204
          ],
          "destructive": true
        }
      ]
    },
    {
      "id": "container-scr-registry",
      "service": "container/scr",
      "enabled": true,
      "steps": [
        {
          "name": "create",
          "method": "POST",
          "path": "/v1/container-registries",
          "json": {
            "name": "regrscr{unique}",
            "private_acl_enabled": false,
            "private_acl_resources": [],
            "public_acl_resources": [],
            "public_visible_enabled": false
          },
          "expect_status": [
            200,
            201,
            202
          ],
          "capture": {
            "reg_id": "$.id"
          },
          "cleanup": {
            "method": "DELETE",
            "path": "/v1/container-registries/{reg_id}",
            "service": "scr"
          }
        },
        {
          "name": "wait-running",
          "method": "GET",
          "path": "/v1/container-registries/{reg_id}",
          "expect_status": [
            200
          ],
          "poll": {
            "field": "$.state",
            "until": [
              "Running",
              "RUNNING",
              "active",
              "ACTIVE"
            ],
            "timeout": 180,
            "interval": 10
          }
        },
        {
          "name": "list",
          "method": "GET",
          "path": "/v1/container-registries",
          "expect_status": [
            200
          ]
        },
        {
          "name": "delete",
          "method": "DELETE",
          "path": "/v1/container-registries/{reg_id}",
          "expect_status": [
            200,
            202,
            204
          ],
          "destructive": true,
          "retry_on_status": [
            500
          ],
          "retries": 12,
          "retry_interval": 30
        },
        {
          "name": "wait-gone",
          "method": "GET",
          "path": "/v1/container-registries/{reg_id}",
          "expect_status": [
            200,
            404
          ],
          "poll": {
            "until_status": [
              404
            ],
            "timeout": 180,
            "interval": 10
          }
        }
      ],
      "_note": "Registry DELETE returns 500 for a few minutes right after creation (provisioning race), then succeeds; the delete step retries 500 up to ~6 min. Enabled."
    },
    {
      "id": "filestorage-volume",
      "service": "storage/filestorage",
      "enabled": true,
      "steps": [
        {
          "name": "create",
          "method": "POST",
          "path": "/v1/volumes",
          "json": {
            "name": "regrfs{unique}",
            "protocol": "NFS",
            "type_name": "HDD"
          },
          "expect_status": [
            200,
            201,
            202
          ],
          "capture": {
            "volume_id": "$.volume_id"
          },
          "cleanup": {
            "method": "DELETE",
            "path": "/v1/volumes/{volume_id}",
            "service": "filestorage"
          }
        },
        {
          "name": "wait-available",
          "method": "GET",
          "path": "/v1/volumes/{volume_id}",
          "expect_status": [
            200
          ],
          "poll": {
            "field": "$.state",
            "until": [
              "available",
              "AVAILABLE",
              "ACTIVE"
            ],
            "timeout": 300,
            "interval": 15
          }
        },
        {
          "name": "list",
          "method": "GET",
          "path": "/v1/volumes",
          "expect_status": [
            200
          ]
        },
        {
          "name": "delete",
          "method": "DELETE",
          "path": "/v1/volumes/{volume_id}",
          "expect_status": [
            200,
            202,
            204
          ],
          "destructive": true
        },
        {
          "name": "wait-gone",
          "method": "GET",
          "path": "/v1/volumes/{volume_id}",
          "expect_status": [
            200,
            404
          ],
          "poll": {
            "until_status": [
              404
            ],
            "timeout": 300,
            "interval": 15
          }
        }
      ]
    },
    {
      "id": "security-certificatemanager-selfsign",
      "service": "security/certificatemanager",
      "enabled": true,
      "_note": "Light, self-contained: issue a self-signed certificate, read it, list, delete. Synchronous.",
      "steps": [
        {
          "name": "create",
          "method": "POST",
          "path": "/v1/certificatemanager/self-sign",
          "json": {
            "cn": "regr{unique}.example.com",
            "name": "regrcert{unique}",
            "not_before_dt": "{today}",
            "not_after_dt": "{today_plus_5y}",
            "organization": "regression",
            "recipients": [],
            "region": "{region}",
            "tags": [],
            "timezone": "Asia/Seoul"
          },
          "expect_status": [
            200,
            201
          ],
          "capture": {
            "cert_id": "$.certificate.id"
          },
          "cleanup": {
            "method": "DELETE",
            "path": "/v1/certificatemanager/{cert_id}",
            "service": "certificatemanager"
          }
        },
        {
          "name": "get",
          "method": "GET",
          "path": "/v1/certificatemanager/{cert_id}",
          "expect_status": [
            200
          ]
        },
        {
          "name": "list",
          "method": "GET",
          "path": "/v1/certificatemanager",
          "expect_status": [
            200
          ]
        },
        {
          "name": "delete",
          "method": "DELETE",
          "path": "/v1/certificatemanager/{cert_id}",
          "expect_status": [
            200,
            202,
            204
          ],
          "destructive": true
        }
      ]
    },
    {
      "id": "application-queueservice-queue",
