# SCP API Regression Test Platform — compose 환경 파일 템플릿 (docs/DEPLOY.md)
#
#   cp .env.platform.example .env.platform   # 그리고 값 채우기
#
# .env.platform은 절대 커밋하지 마세요 (.gitignore에 포함). secret은 이 파일
# (호스트 디스크)에만 존재합니다 — 플랫폼/DB는 credential을 저장하지 않습니다
# (PLATFORM-PLAN §1 원칙 3).

# ── 실행기 선택 ────────────────────────────────────────────────────────────────
# docker-compose.yml이 PLATFORM_EXECUTOR=worker를 강제합니다 (environment: 가
# env_file보다 우선). Actions 실행기로 되돌리려면 compose 파일의 해당 줄을
# 지우고 아래를 actions로 + PLATFORM_GITHUB_*를 설정하세요.
#PLATFORM_EXECUTOR=worker

# ── SCP API credentials (필수 — 엔진이 live API를 호출) ───────────────────────
SCP_ACCESS_KEY=
SCP_SECRET_KEY=
SCP_PROJECT_ID=

# ── 대상 환경 (environments/*.yaml 프로파일을 쓰면 run별로 덮어씀) ─────────────
SCP_REGION=kr-west1
SCP_ENV=e
#SCP_SERVICE_HOSTS=
#SCP_HOST_TEMPLATE=
#SCP_AUTH_SCHEME=hmac
#SCP_TIMEOUT=20
#SCP_MAX_RETRIES=2

# ── oplog / 스냅샷 버킷 (S3 호환; 미설정 시 self-disable — UI는 DB로 동작) ─────
#SCP_OPLOG_BUCKET=apitest-oplog-permanent
#SCP_OPLOG_S3_ENDPOINT=
#SCP_OPLOG_ACCESS_KEY=
#SCP_OPLOG_SECRET_KEY=

# ── 워크플로우 게이트의 repo-Variable 대응물 (보통 비움 — suite가 결정) ────────
#SCP_RUN_CRUD=
#SCP_RUN_HEAVY=
#SCP_RUN_CONFORMANCE=
# 인벤토리 화면의 단일 리소스 삭제 버튼 활성화
#SCP_ALLOW_DESTRUCTIVE=

# ── 플랫폼 서버 ────────────────────────────────────────────────────────────────
# SQLite 경로 (기본 controlplane/data/platform.db — repo 볼륨 안, 이전=디렉토리 이동)
#PLATFORM_DB=
# 엔진→서버 ingest/명령 채널 Bearer 토큰 (설정 시 아래 APITEST_PLATFORM_TOKEN과 동일 값)
#PLATFORM_INGEST_TOKEN=
#APITEST_PLATFORM_TOKEN=
# UI 편집 저장(로컬 커밋) 후 git push까지 수행 — 기본 off (git은 이력/백업 용도)
#PLATFORM_GIT_PUSH=
# worker 스테이지 타임아웃 초 (기본 18000 = 300분, 워크플로우와 동일)
#PLATFORM_WORKER_STAGE_TIMEOUT=

# ── GitHub Actions 실행기로 되돌릴 때만 (PLATFORM_EXECUTOR=actions) ────────────
#PLATFORM_GITHUB_TOKEN=
#PLATFORM_GITHUB_REPO=owner/repo
#PLATFORM_GITHUB_REF=main
#PLATFORM_GITHUB_WORKFLOW=api-test.yml

# ── AI (선택 — 미설정 시 triage/AI 파이프라인 비활성) ──────────────────────────
#ANTHROPIC_API_KEY=
#PLATFORM_TRIAGE_MODEL=claude-opus-4-8
#PLATFORM_AUTO_TRIAGE=
#PLATFORM_NOTIFY_WEBHOOK=
